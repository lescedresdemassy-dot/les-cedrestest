# =========================================================
# EEB MASSY — Variables d'environnement
# Copier vers .env.local (NE JAMAIS COMMIT .env.local)
# =========================================================

# ---- Supabase (à brancher par toi) ----
PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx

# ---- Email (SendGrid / Resend / autre) ----
EMAIL_FROM=contact@eglise-massy.fr
EMAIL_API_KEY=

# ---- CSRF secret (générer avec: openssl rand -base64 32) ----
CSRF_SECRET=changeme-very-long-random-string-min-32-chars

# ---- Monitoring (optionnel) ----
SENTRY_DSN=

# ---- Mode ----
NODE_ENV=development
