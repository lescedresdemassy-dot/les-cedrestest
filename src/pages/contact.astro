---
import PageLayout from '../layouts/PageLayout.astro';
import Container from '../components/Container.astro';
import { church } from '../data/church.ts';
export const prerender = true;
---

<PageLayout
  title="Contact — Nous écrire, nous appeler, nous rendre visite"
  description={`Adresse, téléphone, formulaire de contact et accès en transport. EEB Massy, ${church.address.full}.`}
  eyebrow="Contact"
  pageTitle="Nous contacter"
  pageLead="Que vous ayez une question sur nos activités, un besoin de prière ou l'envie de nous rendre visite le dimanche, n'hésitez pas à nous écrire."
>
  <section class="py-16 bg-grain">
    <Container size="default">
      <div class="grid grid-cols-1 gap-16 lg:grid-cols-12 lg:gap-16">
        
        <!-- Contact Form (Left 7 Cols) -->
        <div class="lg:col-span-7">
          <form id="contact-form" class="space-y-6" novalidate>
            <input type="hidden" name="csrfToken" data-csrf-token />
            <input
              type="text"
              name="website"
              class="honeypot"
              tabindex="-1"
              autocomplete="off"
              aria-hidden="true"
            />

            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
              <div>
                <label
                  for="name"
                  class="block text-xs font-semibold uppercase tracking-wider text-ink-700 dark:text-ink-200"
                >
                  Nom complet *
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  minlength="2"
                  maxlength="100"
                  autocomplete="name"
                  class="input-editorial mt-1"
                />
              </div>

              <div>
                <label
                  for="email"
                  class="block text-xs font-semibold uppercase tracking-wider text-ink-700 dark:text-ink-200"
                >
                  Adresse email *
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  maxlength="254"
                  autocomplete="email"
                  class="input-editorial mt-1"
                />
              </div>
            </div>

            <div>
              <label
                for="phone"
                class="block text-xs font-semibold uppercase tracking-wider text-ink-700 dark:text-ink-200"
              >
                Numéro de téléphone <span class="font-normal text-ink-500">(facultatif)</span>
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                maxlength="20"
                autocomplete="tel"
                placeholder="Ex. 06 12 34 56 78"
                class="input-editorial mt-1"
              />
            </div>

            <div>
              <label
                for="subject"
                class="block text-xs font-semibold uppercase tracking-wider text-ink-700 dark:text-ink-200"
              >
                Sujet de votre message *
              </label>
              <select
                id="subject"
                name="subject"
                required
                class="input-editorial mt-1"
              >
                <option value="" class="dark:bg-ink-950">Sélectionnez une option...</option>
                <option value="general" class="dark:bg-ink-950">Question générale</option>
                <option value="visite" class="dark:bg-ink-950">Venir nous visiter</option>
                <option value="priere" class="dark:bg-ink-950">Demande de prière</option>
                <option value="pastoral" class="dark:bg-ink-950">Demande d'entretien pastoral</option>
                <option value="autre" class="dark:bg-ink-950">Autre demande</option>
              </select>
            </div>

            <div>
              <label
                for="message"
                class="block text-xs font-semibold uppercase tracking-wider text-ink-700 dark:text-ink-200"
              >
                Votre message *
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="5"
                minlength="10"
                maxlength="5000"
                placeholder="Écrivez votre message ici..."
                class="input-editorial mt-1 resize-y"
              ></textarea>
              <p class="mt-2 text-[10px] text-ink-400 dark:text-ink-500 uppercase tracking-wider">
                <span data-char-count>0</span> / 5000 caractères
              </p>
            </div>

            <div class="border-t border-b border-editorial py-5 text-xs text-ink-600 dark:text-ink-400">
              <p>
                <strong class="font-medium text-ink-800 dark:text-ink-200">Confidentialité :</strong> Les informations recueillies sur ce formulaire sont uniquement destinées au traitement de votre demande par l'équipe d'animation. Elles ne sont ni vendues ni cédées à des tiers.
              </p>
            </div>

            <div class="flex flex-wrap items-center gap-6 pt-2">
              <button
                type="submit"
                class="inline-flex h-12 items-center gap-2 rounded-none bg-ink-900 px-8 text-xs font-semibold uppercase tracking-[0.15em] text-white hover:bg-terracotta-700 transition-colors duration-200 dark:bg-ink-100 dark:text-ink-950 dark:hover:bg-terracotta-400"
              >
                Envoyer le message
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </button>

              <p data-form-result class="hidden text-sm font-medium" role="status" aria-live="polite"></p>
            </div>
          </form>
        </div>

        <!-- Sidebar Info (Right 5 Cols) -->
        <aside class="space-y-8 lg:col-span-5 lg:border-l border-editorial lg:pl-10">
          
          <!-- Quick contact entries -->
          <div class="space-y-6">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-500 dark:text-ink-450">
                Téléphone de l'accueil
              </p>
              <a
                href={`tel:${church.contact.phoneE164}`}
                class="mt-1.5 inline-block font-display text-xl font-medium text-ink-900 hover:text-terracotta-700 dark:text-ink-50 dark:hover:text-terracotta-300 transition-colors"
              >
                {church.contact.phone}
              </a>
              <p class="mt-1 text-xs text-ink-550 dark:text-ink-400">
                Ligne fixe. En cas d'absence, laissez un message vocal.
              </p>
            </div>

            <div class="border-t border-editorial pt-6">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-500 dark:text-ink-450">
                Adresse postale & Culte
              </p>
              <address class="mt-2 not-italic text-sm text-ink-800 dark:text-ink-200 space-y-1">
                <p class="font-medium text-ink-900 dark:text-ink-50">Centre Évangélique Les Cèdres</p>
                <p>{church.address.street}</p>
                <p>{church.address.postalCode} {church.address.city}</p>
              </address>
              <p class="mt-3 text-xs text-ink-550 dark:text-ink-400">
                Rejoignez-nous tous les dimanches matin à 10h30.
              </p>
            </div>

            <!-- Transport details -->
            <div class="border-t border-editorial pt-6">
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-500 dark:text-ink-450">
                Itinéraires et Transports
              </p>
              <div class="mt-3 space-y-4 text-xs text-ink-700 dark:text-ink-300">
                <div>
                  <span class="font-bold text-terracotta-700 dark:text-terracotta-300 mr-2">[DIMANCHE]</span>
                  <span>{church.transport.sunday}</span>
                </div>
                <div>
                  <span class="font-bold text-sage-700 dark:text-sage-300 mr-2">[SEMAINE]</span>
                  <span>{church.transport.weekday}</span>
                </div>
                <div>
                  <span class="font-bold text-ink-500 mr-2">[ALTERNATIVE]</span>
                  <span>{church.transport.alternative}</span>
                </div>
              </div>
            </div>

            <!-- Response time expectations -->
            <div class="border-t border-editorial pt-6 text-xs text-ink-500 dark:text-ink-400">
              <p>
                ✦ Nous lisons les courriels régulièrement et nous efforçons d'y répondre sous 24h à 48h (jours ouvrés).
              </p>
            </div>
          </div>

        </aside>
      </div>
    </Container>
  </section>

  <!-- Interactive Map section -->
  <section class="pb-20 bg-grain">
    <Container size="default">
      <div class="overflow-hidden border border-editorial">
        <iframe
          src={church.address.googleMapsEmbed}
          width="100%"
          height="450"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Carte interactive de l'EEB Massy"
          class="block"
        ></iframe>
      </div>
    </Container>
  </section>

  <!-- Contact Form client-side handling JS -->
  <script>
    function setupContactForm() {
      const form = document.getElementById('contact-form') as HTMLFormElement | null;
      const result = document.querySelector<HTMLElement>('[data-form-result]');
      const charCount = document.querySelector<HTMLElement>('[data-char-count]');
      const messageEl = document.getElementById('message') as HTMLTextAreaElement | null;
      const csrfInput = document.querySelector<HTMLInputElement>('[data-csrf-token]');
      if (!form || !result) return;

      // Message Char Count
      if (messageEl && charCount) {
        messageEl.addEventListener('input', () => {
          charCount.textContent = String(messageEl.value.length);
        });
      }

      // CSRF request
      fetch('/api/csrf')
        .then((r) => r.json())
        .then((d) => {
          if (csrfInput && d.token) csrfInput.value = d.token;
        })
        .catch(() => {});

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = Object.fromEntries(new FormData(form).entries());
        
        result.className = 'text-xs font-semibold uppercase tracking-wider text-ink-500';
        result.classList.remove('hidden');
        result.textContent = 'Envoi du message...';

        try {
          const res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(formData),
          });
          const data = await res.json();
          if (data.success || data.ok) {
            result.className = 'text-sm font-medium text-sage-700 dark:text-sage-400';
            result.textContent = '✓ Message envoyé ! Nous vous répondrons rapidement.';
            form.reset();
            if (charCount) charCount.textContent = '0';
          } else {
            result.className = 'text-sm font-medium text-terracotta-700 dark:text-terracotta-400';
            result.textContent = data.error || 'Erreur lors de l\'envoi. Réessayez.';
          }
        } catch (err) {
          result.className = 'text-sm font-medium text-terracotta-700 dark:text-terracotta-400';
          result.textContent = 'Erreur de connexion. Vérifiez votre réseau.';
        }
      });
    }

    if (document.readyState !== 'loading') setupContactForm();
    else document.addEventListener('DOMContentLoaded', setupContactForm);
    document.addEventListener('astro:page-load', setupContactForm);
  </script>
</PageLayout>
