---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/Container.astro';
import Button from '../../components/Button.astro';
import SermonCard from '../../components/SermonCard.astro';
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';
import { sermons, getRelatedSermons } from '../../data/sermons.ts';
import { church } from '../../data/church.ts';

export function getStaticPaths() {
  return sermons.map((sermon) => ({
    params: { id: sermon.id },
    props: { sermon },
  }));
}

const { sermon } = Astro.props;
const related = getRelatedSermons(sermon, 3);

const dateFr = new Date(sermon.date).toLocaleDateString('fr-FR', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const schemaData = {
  '@context': 'https://schema.org',
  '@type': 'VideoObject',
  name: sermon.title,
  description: sermon.description ?? `Prédication par ${sermon.speaker}`,
  uploadDate: sermon.date,
  thumbnailUrl: `https://i.ytimg.com/vi/${sermon.youtubeId}/maxresdefault.jpg`,
  embedUrl: `https://www.youtube.com/embed/${sermon.youtubeId}`,
  publisher: {
    '@type': 'Organization',
    name: church.name,
    logo: {
      '@type': 'ImageObject',
      url: 'https://eglise-massy.fr/logo.png',
    },
  },
};

export const prerender = true;
---

<BaseLayout
  title={`${sermon.title} — ${sermon.speaker}`}
  description={sermon.description ?? `Prédication du ${dateFr} par ${sermon.speaker}${sermon.scripture ? ` — ${sermon.scripture}` : ''}`}
  schema="event"
  schemaData={schemaData}
>
  <!-- ============ HERO DETAILS ============ -->
  <section class="relative pt-12 pb-10 border-b border-editorial bg-grain">
    <Container size="default">
      
      <!-- Ariane -->
      <nav aria-label="Fil d'Ariane" class="mb-8">
        <ol class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wider text-ink-400 dark:text-ink-500">
          <li>
            <a href="/" class="hover:text-terracotta-700 dark:hover:text-terracotta-300">Accueil</a>
          </li>
          <li class="opacity-40">/</li>
          <li>
            <a href="/sermons" class="hover:text-terracotta-700 dark:hover:text-terracotta-300">Prédications</a>
          </li>
          <li class="opacity-40">/</li>
          <li class="truncate text-ink-750 dark:text-ink-300">{sermon.title}</li>
        </ol>
      </nav>

      <div class="max-w-4xl">
        {sermon.series && (
          <p class="mb-5 inline-flex items-center rounded-none border border-terracotta-300/80 bg-transparent px-3 py-1 text-[10px] font-bold uppercase tracking-[0.2em] text-terracotta-700 dark:border-terracotta-900/60 dark:text-terracotta-300">
            Série · {sermon.series}
          </p>
        )}

        <h1 class="font-display text-3xl font-light leading-[1.15] tracking-tight text-ink-900 text-balance dark:text-ink-50 sm:text-4xl md:text-5xl">
          {sermon.title}
        </h1>

        <div class="mt-6 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-ink-600 dark:text-ink-400">
          <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-terracotta-600 dark:text-terracotta-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <time datetime={sermon.date}>{dateFr}</time>
          </span>
          <span class="flex items-center gap-2">
            <svg class="h-4 w-4 text-terracotta-600 dark:text-terracotta-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            Orateur : {sermon.speaker}
          </span>
          {sermon.scripture && (
            <span class="flex items-center gap-2">
              <svg class="h-4 w-4 text-terracotta-600 dark:text-terracotta-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg>
              Scripture : <span class="font-medium text-terracotta-700 dark:text-terracotta-300">{sermon.scripture}</span>
            </span>
          )}
          {sermon.durationMinutes && (
            <span class="flex items-center gap-2">
              <svg class="h-4 w-4 text-terracotta-600 dark:text-terracotta-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              Durée : {sermon.durationMinutes} min
            </span>
          )}
        </div>
      </div>

    </Container>
  </section>

  <!-- ============ PLAYER & TEXT ============ -->
  <section class="py-16 bg-grain">
    <Container size="default">
      
      <!-- Video embed player frame -->
      <YouTubeEmbed videoId={sermon.youtubeId} title={sermon.title} autoload={true} />

      {sermon.description && (
        <div class="mx-auto mt-16 max-w-3xl border-t border-editorial pt-10">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-terracotta-700 dark:text-terracotta-300">
            Résumé de l'enseignement
          </p>
          <p class="mt-4 text-lg leading-relaxed text-ink-700 dark:text-ink-300 text-pretty editorial-indent">
            {sermon.description}
          </p>
        </div>
      )}

      <!-- Share cluster -->
      <div class="mx-auto mt-12 flex max-w-3xl flex-wrap items-center gap-3 border-t border-editorial pt-8">
        <p class="text-xs font-semibold uppercase tracking-wider text-ink-400 dark:text-ink-500 mr-2">Partager :</p>
        <a
          href={`https://www.youtube.com/watch?v=${sermon.youtubeId}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex h-9 items-center gap-2 rounded-none border border-ink-900 bg-transparent px-4 text-xs font-semibold uppercase tracking-wider text-ink-900 hover:bg-ink-900 hover:text-white dark:border-ink-100 dark:text-ink-100 dark:hover:bg-ink-100 dark:hover:text-ink-950 transition-colors"
        >
          Regarder sur YouTube
        </a>
        <button
          type="button"
          data-share-button
          class="inline-flex h-9 items-center gap-2 rounded-none border border-ink-900 bg-transparent px-4 text-xs font-semibold uppercase tracking-wider text-ink-900 hover:bg-ink-900 hover:text-white dark:border-ink-100 dark:text-ink-100 dark:hover:bg-ink-100 dark:hover:text-ink-950 transition-colors"
        >
          Copier le lien
        </button>
        <span data-share-success class="hidden text-xs font-medium text-sage-700 dark:text-sage-300">✓ Lien copié !</span>
      </div>

    </Container>
  </section>

  <!-- ============ RELATED SERMONS ============ -->
  {related.length > 0 && (
    <section class="border-t border-editorial bg-sand-50/50 py-20 dark:bg-ink-950/40">
      <Container size="default">
        <div class="mb-12 flex flex-wrap items-end justify-between gap-6">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-terracotta-700 dark:text-terracotta-300">
              Continuer l'écoute
            </p>
            <h2 class="mt-3 font-display text-2xl font-medium tracking-tight text-ink-900 dark:text-ink-50 sm:text-3xl">
              Prédications similaires
            </h2>
          </div>
          <Button href="/sermons" variant="link" icon="arrow">
            Toutes les prédications
          </Button>
        </div>

        <div class="grid grid-cols-1 gap-x-8 gap-y-12 md:grid-cols-2 lg:grid-cols-3">
          {related.map((s) => <SermonCard sermon={s} />)}
        </div>
      </Container>
    </section>
  )}

  <script>
    function setupShare() {
      const btn = document.querySelector<HTMLButtonElement>('[data-share-button]');
      const ok = document.querySelector<HTMLElement>('[data-share-success]');
      if (!btn || !ok) return;
      btn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(window.location.href);
          ok.classList.remove('hidden');
          setTimeout(() => ok.classList.add('hidden'), 2500);
        } catch (e) {
          console.error(e);
        }
      });
    }
    if (document.readyState !== 'loading') setupShare();
    else document.addEventListener('DOMContentLoaded', setupShare);
    document.addEventListener('astro:page-load', setupShare);
  </script>
</BaseLayout>
