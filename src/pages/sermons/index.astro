---
import PageLayout from '../../layouts/PageLayout.astro';
import Container from '../../components/Container.astro';
import Button from '../../components/Button.astro';
import SermonCard from '../../components/SermonCard.astro';
import {
  sermons,
  getFeaturedSermon,
  getAllSpeakers,
  formatScriptureDisplay,
} from '../../data/sermons.ts';
import { church } from '../../data/church.ts';

const featured = getFeaturedSermon();
const otherSermons = sermons.filter((s) => s.id !== featured.id);
const initialSermons = otherSermons.slice(0, 12);

function getDisplayTitle(title: string): string {
  if (title === title.toUpperCase() && title.length > 5) {
    const lower = title.toLowerCase();
    return lower.charAt(0).toUpperCase() + lower.slice(1);
  }
  return title;
}

const featuredDisplayTitle = getDisplayTitle(featured.title);

// Année par année pour le filtre
const years = Array.from(
  new Set(sermons.map((s) => s.date.substring(0, 4)))
).sort((a, b) => b.localeCompare(a));

// Livres bibliques uniques
const books = Array.from(
  new Set(
    sermons
      .map((s) => {
        if (!s.scripture) return '';
        // If scripture starts with a number followed by space and word (e.g. 1 Samuel or 2 Chroniques)
        const match = s.scripture.match(/^(\d+\s+\w+)/);
        if (match) return match[1];
        return s.scripture.split(' ')[0];
      })
      .filter(Boolean)
  )
).sort();

const speakers = getAllSpeakers();

// Séries / Thématiques pour les lignes horizontales (triées par année réelle)
const latestSermons = sermons.slice(0, 6);
const sermons2026 = sermons.filter((s) => s.date.startsWith('2026')).slice(0, 6);
const sermons2025 = sermons.filter((s) => s.date.startsWith('2025')).slice(0, 6);

export const prerender = true;
---

<PageLayout
  title="Prédications — Enseignements bibliques en vidéo"
  description="Parcourez notre bibliothèque d'enseignements bibliques : vidéos de culte, thématiques de rentrée, et messages d'espérance."
  eyebrow="Bibliothèque"
  pageTitle="Toutes nos prédications"
  pageLead={`${sermons.length} enseignements à écouter en vidéo. Retrouvez ici nos messages dominicaux, classés par orateur, thème ou série biblique.`}
>
  <slot name="hero-extra">
    <div class="mt-8 flex flex-wrap gap-3">
      <Button
        href={church.social.youtube.sermonsPlaylist}
        variant="primary"
        size="md"
        external
        icon="youtube"
      >
        Playlist YouTube
      </Button>
      <Button
        href={church.social.youtube.channel}
        variant="secondary"
        size="md"
        external
      >
        Chaîne YouTube de l'église
      </Button>
    </div>
  </slot>

  <!-- ============ FEATURED SERMON SECTION (ASYMMETRICAL DISPOSITION) ============ -->
  <section class="py-16 md:py-24 border-b border-editorial bg-grain">
    <Container size="default">
      <div class="mb-10 flex items-center gap-3 text-[10px] uppercase tracking-[0.25em] text-terracotta-700 dark:text-terracotta-300">
        <span class="h-1.5 w-1.5 bg-terracotta-600 dark:bg-terracotta-400"></span>
        <span>À la une · Dernier message</span>
      </div>

      <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16 items-center">
        <!-- Visual (Left 7 Cols) -->
        <div class="lg:col-span-7">
          <a
            href={`/sermons/${featured.id}`}
            class="group relative block aspect-video w-full bg-sand-100 dark:bg-ink-850 border border-editorial overflow-hidden"
            aria-label={`Regarder : ${featured.title}`}
          >
            <img
              src={`https://i.ytimg.com/vi/${featured.youtubeId}/maxresdefault.jpg`}
              onerror={`this.onerror=null;this.src='https://i.ytimg.com/vi/${featured.youtubeId}/hqdefault.jpg';`}
              alt=""
              loading="eager"
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-out-expo group-hover:scale-102"
            />
            <div class="absolute inset-0 bg-ink-950/10"></div>
            <div class="absolute inset-0 flex items-center justify-center">
              <span class="flex h-14 w-14 items-center justify-center bg-ink-900 text-white dark:bg-ink-100 dark:text-ink-950" aria-hidden="true">
                <svg class="ml-0.5 h-6 w-6" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"></path></svg>
              </span>
            </div>
            {featured.durationMinutes && (
              <span class="absolute bottom-4 right-4 bg-ink-950/80 px-2.5 py-0.5 text-[10px] font-semibold text-white tracking-wide">
                {featured.durationMinutes >= 60 
                  ? `${Math.floor(featured.durationMinutes / 60)} h ${String(featured.durationMinutes % 60).padStart(2, '0')}`
                  : `${featured.durationMinutes} min`}
              </span>
            )}
          </a>
        </div>

        <!-- Content details (Right 5 Cols) -->
        <div class="lg:col-span-5 flex flex-col justify-center">
          <div class="flex items-center gap-2.5 text-xs text-ink-500 dark:text-ink-400 uppercase tracking-wider font-semibold">
            <time datetime={featured.date}>
              {new Date(featured.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
            </time>
            {featured.scripture && (
              <>
                <span>·</span>
                <span class="font-medium text-terracotta-700 dark:text-terracotta-300">{formatScriptureDisplay(featured.scripture)}</span>
              </>
            )}
          </div>

          <h3 class="mt-4 font-display text-3xl font-light leading-tight tracking-tight text-ink-900 dark:text-ink-50 sm:text-4xl">
            <a href={`/sermons/${featured.id}`} class="hover:text-terracotta-700 dark:hover:text-terracotta-300 transition-colors">
              {featuredDisplayTitle}
            </a>
          </h3>

          <p class="mt-3 text-xs text-ink-550 dark:text-ink-400 font-medium">
            Par {featured.speaker} {featured.series ? `· Série : ${featured.series}` : ''}
          </p>

          <p class="mt-6 text-sm leading-relaxed text-ink-700 dark:text-ink-300">
            {featured.description || "Retrouvez l'enseignement biblique partagé ce dimanche au Centre Les Cèdres."}
          </p>

          <div class="mt-8 flex flex-wrap gap-4">
            <Button href={`/sermons/${featured.id}`} variant="primary" size="md">
              Regarder le message
            </Button>
            <a href="#toutes-les-predications" class="link-editorial text-xs font-semibold uppercase tracking-wider self-center ml-2">
              Rechercher une autre vidéo
            </a>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- ============ CURATED ROW 1: DERNIERES PREDICATIONS ============ -->
  <section class="py-16 border-b border-editorial bg-grain overflow-hidden">
    <Container size="default">
      <div class="mb-8 flex items-baseline justify-between">
        <div>
          <h2 class="font-display text-2xl font-light tracking-tight text-ink-900 dark:text-ink-50">
            Dernières prédications
          </h2>
          <p class="text-xs text-ink-500 dark:text-ink-400 mt-1">
            Les derniers cultes et messages dominicaux
          </p>
        </div>
        <a href="#toutes-les-predications" class="link-editorial text-xs font-semibold uppercase tracking-wider">
          Tout voir
        </a>
      </div>

      <div class="relative group/row">
        <!-- Horizontal Scroll Container -->
        <div
          class="flex gap-6 overflow-x-auto snap-x snap-mandatory py-4 scrollbar-none"
          data-scroll-track
        >
          {latestSermons.map((s) => (
            <div class="snap-start shrink-0 min-w-[280px] w-[280px] sm:min-w-[320px] sm:w-[320px] md:min-w-[360px] md:w-[360px]">
              <SermonCard sermon={s} />
            </div>
          ))}
        </div>
        <!-- Desktop controls -->
        <button
          type="button"
          class="absolute -left-4 top-[35%] -translate-y-1/2 z-10 hidden lg:flex items-center justify-center h-10 w-10 border border-editorial bg-sand-50 dark:bg-ink-950 text-ink-900 dark:text-ink-50 hover:bg-terracotta-700 hover:text-white transition-colors"
          data-scroll-btn="prev"
          aria-label="Précédent"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m15 18-6-6 6-6"/></svg>
        </button>
        <button
          type="button"
          class="absolute -right-4 top-[35%] -translate-y-1/2 z-10 hidden lg:flex items-center justify-center h-10 w-10 border border-editorial bg-sand-50 dark:bg-ink-950 text-ink-900 dark:text-ink-50 hover:bg-terracotta-700 hover:text-white transition-colors"
          data-scroll-btn="next"
          aria-label="Suivant"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
        </button>
      </div>
    </Container>
  </section>

  <!-- ============ EDITORIAL SERIES & THEMES ============ -->
  <section class="py-16 border-b border-editorial bg-grain overflow-hidden">
    <Container size="default">
      <div class="mb-12">
        <span class="text-xs font-semibold uppercase tracking-[0.2em] text-terracotta-700 dark:text-terracotta-300">Thématiques</span>
        <h2 class="font-display text-3xl font-light tracking-tight text-ink-900 dark:text-ink-50 mt-2">
          Séries d'enseignements bibliques
        </h2>
      </div>

      <!-- Collection 1: Galates -->
      <div class="mb-12">
        <h3 class="font-display text-xl font-medium text-ink-900 dark:text-ink-50 mb-6">Série sur les Galates</h3>
        <div class="relative group/row">
          <div class="flex gap-6 overflow-x-auto snap-x snap-mandatory py-4 scrollbar-none" data-scroll-track>
            {sermons.filter(s => s.scripture?.startsWith('Galates') || s.series?.toLowerCase().includes('galates')).map((s) => (
              <div class="snap-start shrink-0 min-w-[280px] w-[280px] sm:min-w-[320px] sm:w-[320px] md:min-w-[360px] md:w-[360px]">
                <SermonCard sermon={s} />
              </div>
            ))}
          </div>
          <button type="button" class="absolute -left-4 top-[35%] -translate-y-1/2 z-10 hidden lg:flex items-center justify-center h-10 w-10 border border-editorial bg-sand-50 dark:bg-ink-950 text-ink-900 dark:text-ink-50 hover:bg-terracotta-700 hover:text-white transition-colors" data-scroll-btn="prev" aria-label="Précédent">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <button type="button" class="absolute -right-4 top-[35%] -translate-y-1/2 z-10 hidden lg:flex items-center justify-center h-10 w-10 border border-editorial bg-sand-50 dark:bg-ink-950 text-ink-900 dark:text-ink-50 hover:bg-terracotta-700 hover:text-white transition-colors" data-scroll-btn="next" aria-label="Suivant">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>
      </div>

      <!-- Collection 2: Jacob -->
      <div class="mb-12">
        <h3 class="font-display text-xl font-medium text-ink-900 dark:text-ink-50 mb-6">L'histoire de Jacob</h3>
        <div class="relative group/row">
          <div class="flex gap-6 overflow-x-auto snap-x snap-mandatory py-4 scrollbar-none" data-scroll-track>
            {sermons.filter(s => s.series === 'Jacob').map((s) => (
              <div class="snap-start shrink-0 min-w-[280px] w-[280px] sm:min-w-[320px] sm:w-[320px] md:min-w-[360px] md:w-[360px]">
                <SermonCard sermon={s} />
              </div>
            ))}
          </div>
          <button type="button" class="absolute -left-4 top-[35%] -translate-y-1/2 z-10 hidden lg:flex items-center justify-center h-10 w-10 border border-editorial bg-sand-50 dark:bg-ink-950 text-ink-900 dark:text-ink-50 hover:bg-terracotta-700 hover:text-white transition-colors" data-scroll-btn="prev" aria-label="Précédent">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <button type="button" class="absolute -right-4 top-[35%] -translate-y-1/2 z-10 hidden lg:flex items-center justify-center h-10 w-10 border border-editorial bg-sand-50 dark:bg-ink-950 text-ink-900 dark:text-ink-50 hover:bg-terracotta-700 hover:text-white transition-colors" data-scroll-btn="next" aria-label="Suivant">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>
      </div>

      <!-- Collection 3: Portrait de disciples -->
      <div>
        <h3 class="font-display text-xl font-medium text-ink-900 dark:text-ink-50 mb-6">Portraits de disciples</h3>
        <div class="relative group/row">
          <div class="flex gap-6 overflow-x-auto snap-x snap-mandatory py-4 scrollbar-none" data-scroll-track>
            {sermons.filter(s => s.series === 'Portrait de disciples').map((s) => (
              <div class="snap-start shrink-0 min-w-[280px] w-[280px] sm:min-w-[320px] sm:w-[320px] md:min-w-[360px] md:w-[360px]">
                <SermonCard sermon={s} />
              </div>
            ))}
          </div>
          <button type="button" class="absolute -left-4 top-[35%] -translate-y-1/2 z-10 hidden lg:flex items-center justify-center h-10 w-10 border border-editorial bg-sand-50 dark:bg-ink-950 text-ink-900 dark:text-ink-50 hover:bg-terracotta-700 hover:text-white transition-colors" data-scroll-btn="prev" aria-label="Précédent">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <button type="button" class="absolute -right-4 top-[35%] -translate-y-1/2 z-10 hidden lg:flex items-center justify-center h-10 w-10 border border-editorial bg-sand-50 dark:bg-ink-950 text-ink-900 dark:text-ink-50 hover:bg-terracotta-700 hover:text-white transition-colors" data-scroll-btn="next" aria-label="Suivant">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>
      </div>

    </Container>
  </section>

  <!-- ============ CURATED ROW 2: ANNEE 2026 ============ -->
  {sermons2026.length > 0 && (
    <section class="py-16 border-b border-editorial bg-grain overflow-hidden">
      <Container size="default">
        <div class="mb-8 flex items-baseline justify-between">
          <div>
            <h2 class="font-display text-2xl font-light tracking-tight text-ink-900 dark:text-ink-50">
              Année 2026
            </h2>
            <p class="text-xs text-ink-500 dark:text-ink-400 mt-1">
              Les messages partagés depuis le début de l'année
            </p>
          </div>
          <button
            type="button"
            data-trigger-filter-year="2026"
            class="link-editorial text-xs font-semibold uppercase tracking-wider"
          >
            Tout voir
          </button>
        </div>

        <div class="relative group/row">
          <!-- Horizontal Scroll Container -->
          <div
            class="flex gap-6 overflow-x-auto snap-x snap-mandatory py-4 scrollbar-none"
            data-scroll-track
          >
            {sermons2026.map((s) => (
              <div class="snap-start shrink-0 min-w-[280px] w-[280px] sm:min-w-[320px] sm:w-[320px] md:min-w-[360px] md:w-[360px]">
                <SermonCard sermon={s} />
              </div>
            ))}
          </div>
          <!-- Desktop controls -->
          <button
            type="button"
            class="absolute -left-4 top-[35%] -translate-y-1/2 z-10 hidden lg:flex items-center justify-center h-10 w-10 border border-editorial bg-sand-50 dark:bg-ink-950 text-ink-900 dark:text-ink-50 hover:bg-terracotta-700 hover:text-white transition-colors"
            data-scroll-btn="prev"
            aria-label="Précédent"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <button
            type="button"
            class="absolute -right-4 top-[35%] -translate-y-1/2 z-10 hidden lg:flex items-center justify-center h-10 w-10 border border-editorial bg-sand-50 dark:bg-ink-950 text-ink-900 dark:text-ink-50 hover:bg-terracotta-700 hover:text-white transition-colors"
            data-scroll-btn="next"
            aria-label="Suivant"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>
      </Container>
    </section>
  )}

  <!-- ============ CURATED ROW 3: ANNEE 2025 ============ -->
  {sermons2025.length > 0 && (
    <section class="py-16 border-b border-editorial bg-grain overflow-hidden">
      <Container size="default">
        <div class="mb-8 flex items-baseline justify-between">
          <div>
            <h2 class="font-display text-2xl font-light tracking-tight text-ink-900 dark:text-ink-50">
              Année 2025
            </h2>
            <p class="text-xs text-ink-500 dark:text-ink-400 mt-1">
              Archives des prédications de l'année précédente
            </p>
          </div>
          <button
            type="button"
            data-trigger-filter-year="2025"
            class="link-editorial text-xs font-semibold uppercase tracking-wider"
          >
            Tout voir
          </button>
        </div>

        <div class="relative group/row">
          <!-- Horizontal Scroll Container -->
          <div
            class="flex gap-6 overflow-x-auto snap-x snap-mandatory py-4 scrollbar-none"
            data-scroll-track
          >
            {sermons2025.map((s) => (
              <div class="snap-start shrink-0 min-w-[280px] w-[280px] sm:min-w-[320px] sm:w-[320px] md:min-w-[360px] md:w-[360px]">
                <SermonCard sermon={s} />
              </div>
            ))}
          </div>
          <!-- Desktop controls -->
          <button
            type="button"
            class="absolute -left-4 top-[35%] -translate-y-1/2 z-10 hidden lg:flex items-center justify-center h-10 w-10 border border-editorial bg-sand-50 dark:bg-ink-950 text-ink-900 dark:text-ink-50 hover:bg-terracotta-700 hover:text-white transition-colors"
            data-scroll-btn="prev"
            aria-label="Précédent"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <button
            type="button"
            class="absolute -right-4 top-[35%] -translate-y-1/2 z-10 hidden lg:flex items-center justify-center h-10 w-10 border border-editorial bg-sand-50 dark:bg-ink-950 text-ink-900 dark:text-ink-50 hover:bg-terracotta-700 hover:text-white transition-colors"
            data-scroll-btn="next"
            aria-label="Suivant"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>
      </Container>
    </section>
  )}

  <!-- ============ COMPLETE LIBRARY SECTION ============ -->
  <section id="toutes-les-predications" class="py-16 md:py-24 bg-grain scroll-mt-20">
    <Container size="default">
      
      <div class="mb-10">
        <h2 class="font-display text-3xl font-light tracking-tight text-ink-900 dark:text-ink-50">
          Toutes les prédications
        </h2>
        <p class="text-xs text-ink-500 dark:text-ink-400 mt-1">
          Explorez et filtrez l'intégralité de nos archives d'enseignements
        </p>
      </div>

      <!-- Custom Typographic Filter Bar (No rounded search box or templates) -->
      <div class="mb-16 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between border-b border-editorial pb-10">
        
        <!-- Search Input -->
        <div class="w-full lg:max-w-md">
          <label for="sermon-search" class="sr-only">Rechercher une prédication</label>
          <div class="relative">
            <input
              type="search"
              id="sermon-search"
              placeholder="Rechercher par titre, texte biblique, orateur..."
              class="input-editorial pl-2 pr-10"
              data-sermon-search
            />
            <svg
              class="absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-ink-400"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.3-4.3"></path>
            </svg>
          </div>
        </div>

        <!-- Filter Selects -->
        <div class="flex flex-wrap gap-4">
          <select
            class="bg-transparent border-b border-editorial py-2.5 text-xs font-semibold uppercase tracking-wider text-ink-700 focus:outline-none focus:border-terracotta-500 dark:text-ink-300"
            data-sermon-filter="book"
            aria-label="Filtrer par livre biblique"
          >
            <option value="" class="dark:bg-ink-950">Tous les livres</option>
            {books.map((b) => <option value={b} class="dark:bg-ink-950">{b}</option>)}
          </select>

          <select
            class="bg-transparent border-b border-editorial py-2.5 text-xs font-semibold uppercase tracking-wider text-ink-700 focus:outline-none focus:border-terracotta-500 dark:text-ink-300"
            data-sermon-filter="speaker"
            aria-label="Filtrer par prédicateur"
          >
            <option value="" class="dark:bg-ink-950">Tous les prédicateurs</option>
            {speakers.map((s) => <option value={s} class="dark:bg-ink-950">{s}</option>)}
          </select>

          <select
            class="bg-transparent border-b border-editorial py-2.5 text-xs font-semibold uppercase tracking-wider text-ink-700 focus:outline-none focus:border-terracotta-500 dark:text-ink-300"
            data-sermon-filter="year"
            aria-label="Filtrer par année"
          >
            <option value="" class="dark:bg-ink-950">Toutes les années</option>
            {years.map((y) => <option value={y} class="dark:bg-ink-950">{y}</option>)}
          </select>
        </div>
      </div>

      <div id="sermon-empty-container" class="w-full"></div>

      <!-- Sermon Grid -->
      <div
        class="grid grid-cols-1 gap-x-8 gap-y-16 sm:grid-cols-2 lg:grid-cols-3"
        data-sermon-grid
      >
        {initialSermons.map((sermon) => (
          <div
            data-sermon-item
            data-sermon-title={sermon.title.toLowerCase()}
            data-sermon-speaker={sermon.speaker}
            data-sermon-year={sermon.date.substring(0, 4)}
            data-sermon-book={sermon.scripture ? (sermon.scripture.match(/^(\d+\s+\w+)/) ? sermon.scripture.match(/^(\d+\s+\w+)/)![1] : sermon.scripture.split(' ')[0]) : ''}
            data-sermon-scripture={sermon.scripture?.toLowerCase() ?? ''}
          >
            <SermonCard sermon={sermon} />
          </div>
        ))}
      </div>

      <div id="sermon-load-more-container" class="mt-12 flex justify-center">
        <button
          type="button"
          id="btn-load-more"
          class="inline-flex h-12 items-center justify-center border border-ink-900 bg-transparent px-8 text-xs font-semibold uppercase tracking-wider text-ink-900 hover:bg-ink-900 hover:text-white dark:border-ink-100 dark:text-ink-100 dark:hover:bg-ink-100 dark:hover:text-ink-950 transition-colors"
        >
          Afficher plus
        </button>
      </div>

      <!-- Full sermon data embedded to reduce initial DOM size but keep client-side search across full dataset -->
      <script type="application/json" id="sermons-data" is:inline>
        {JSON.stringify(otherSermons)}
      </script>

    </Container>
  </section>

  <!-- CSS override to hide scrollbars from horizontal tracks -->
  <style is:inline>
    .scrollbar-none::-webkit-scrollbar {
      display: none;
    }
    .scrollbar-none {
      -ms-overflow-style: none;
      scrollbar-width: none;
    }
  </style>

  <!-- JS search client-side script -->
  <script>
    function setupSermonFilters() {
      const search = document.querySelector<HTMLInputElement>('[data-sermon-search]');
      const filters = document.querySelectorAll<HTMLSelectElement>('[data-sermon-filter]');
      const emptyContainer = document.getElementById('sermon-empty-container');
      const grid = document.querySelector<HTMLElement>('[data-sermon-grid]');
      const loadMoreContainer = document.getElementById('sermon-load-more-container');
      const btnLoadMore = document.getElementById('btn-load-more');
      
      const sermonsDataEl = document.getElementById('sermons-data');
      if (!search || !emptyContainer || !grid || !sermonsDataEl || !loadMoreContainer || !btnLoadMore) return;

      let allOtherSermons = [];
      try {
        allOtherSermons = JSON.parse(sermonsDataEl.textContent || '[]');
      } catch (e) {
        console.error('Failed to parse sermons data', e);
        return;
      }

      let currentPageSize = 12;

      // Setup screen reader live region if it doesn't exist
      let liveRegion = document.getElementById('sermon-live-announcer');
      if (!liveRegion) {
        liveRegion = document.createElement('div');
        liveRegion.id = 'sermon-live-announcer';
        liveRegion.className = 'sr-only';
        liveRegion.setAttribute('aria-live', 'polite');
        liveRegion.setAttribute('role', 'status');
        document.body.appendChild(liveRegion);
      }

      let debounceTimeout: number;

      const resetAction = () => {
        search.value = '';
        filters.forEach((f) => {
          f.value = '';
        });
        currentPageSize = 12;
        apply(true);
        search.focus();
      };

      function formatScriptureDisplay(scripture: string): string {
        if (!scripture) return '';
        return scripture
          .replace(/(\d+):(\d+)/g, '$1,$2')
          .replace(/(\d+)\s*-\s*(\d+)/g, '$1–$2');
      }

      function getDisplayTitle(title: string): string {
        if (title === title.toUpperCase() && title.length > 5) {
          const lower = title.toLowerCase();
          return lower.charAt(0).toUpperCase() + lower.slice(1);
        }
        return title;
      }

      function renderSermonCard(sermon: any): string {
        const displayTitle = getDisplayTitle(sermon.title);
        const thumbnail = `https://i.ytimg.com/vi/${sermon.youtubeId}/maxresdefault.jpg`;
        const thumbnailFallback = `https://i.ytimg.com/vi/${sermon.youtubeId}/hqdefault.jpg`;
        const dateFr = new Date(sermon.date).toLocaleDateString('fr-FR', {
          day: 'numeric',
          month: 'long',
          year: 'numeric',
        });
        
        const durationText = sermon.durationMinutes 
          ? (sermon.durationMinutes >= 60 
              ? `${Math.floor(sermon.durationMinutes / 60)} h ${String(sermon.durationMinutes % 60).padStart(2, '0')}`
              : `${sermon.durationMinutes} min`)
          : '';

        const durationBadge = durationText 
          ? `<span class="absolute bottom-3 right-3 rounded-none bg-ink-950/80 px-2 py-0.5 text-[10px] font-medium text-white tracking-wide">${durationText}</span>` 
          : '';

        const scriptureSpan = sermon.scripture 
          ? `<span>·</span> <span class="font-medium text-terracotta-700 dark:text-terracotta-300">${formatScriptureDisplay(sermon.scripture)}</span>`
          : '';

        return `
          <article class="group relative flex flex-col transition-all duration-400">
            <a href="/sermons/${sermon.id}" class="relative block overflow-hidden bg-sand-100 dark:bg-ink-850 rounded-none border border-editorial aspect-video w-full" aria-label="Voir la prédication : ${sermon.title.replace(/"/g, '&quot;')}">
              <img src="${thumbnail}" onerror="this.onerror=null;this.src='${thumbnailFallback}';" alt="" loading="lazy" decoding="async" width="640" height="360" class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-out-expo group-hover:scale-102">
              <div class="absolute inset-0 bg-ink-950/10 transition-opacity duration-300 group-hover:opacity-25" aria-hidden="true"></div>
              <div class="absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-350 group-hover:opacity-100">
                <span class="flex h-12 w-12 items-center justify-center rounded-none bg-ink-900 text-white dark:bg-ink-50 dark:text-ink-950" aria-hidden="true">
                  <svg class="ml-0.5 h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"></path></svg>
                </span>
              </div>
              ${durationBadge}
            </a>
            <div class="flex flex-col pt-4">
              <div class="flex items-center gap-2 text-[10px] uppercase tracking-[0.15em] text-ink-500 dark:text-ink-400">
                <time datetime="${sermon.date}">${dateFr}</time>
                ${scriptureSpan}
              </div>
              <h3 class="font-display font-medium tracking-tight text-ink-900 dark:text-ink-50 text-balance mt-3 text-lg group-hover:text-terracotta-700 dark:group-hover:text-terracotta-300 transition-colors">
                <a href="/sermons/${sermon.id}">${displayTitle}</a>
              </h3>
              <p class="mt-1 text-[10px] uppercase tracking-wider text-ink-400 dark:text-ink-500 font-medium">${sermon.speaker}</p>
              <div class="mt-4 pt-1">
                <span class="inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wider text-terracotta-700 group-hover:text-terracotta-800 dark:text-terracotta-300 dark:group-hover:text-terracotta-200 transition-colors">
                  Regarder
                  <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
                </span>
              </div>
            </div>
          </article>
        `;
      }

      const apply = (announce = false) => {
        const q = search.value.trim().toLowerCase();
        const book = (document.querySelector('[data-sermon-filter="book"]') as HTMLSelectElement | null)?.value ?? '';
        const speaker = (document.querySelector('[data-sermon-filter="speaker"]') as HTMLSelectElement | null)?.value ?? '';
        const year = (document.querySelector('[data-sermon-filter="year"]') as HTMLSelectElement | null)?.value ?? '';
        
        const isFiltering = Boolean(q || book || speaker || year);

        let filtered = allOtherSermons;
        if (isFiltering) {
          filtered = allOtherSermons.filter((sermon: any) => {
            const title = sermon.title.toLowerCase();
            const itemSpeaker = sermon.speaker;
            const itemYear = sermon.date.substring(0, 4);
            
            let itemBook = '';
            if (sermon.scripture) {
              const match = sermon.scripture.match(/^(\d+\s+\w+)/);
              itemBook = match ? match[1] : sermon.scripture.split(' ')[0];
            }
            
            const scripture = (sermon.scripture || '').toLowerCase();

            const matchQ = !q || title.includes(q) || itemSpeaker.toLowerCase().includes(q) || scripture.includes(q);
            const matchBook = !book || itemBook === book;
            const matchSpeaker = !speaker || itemSpeaker === speaker;
            const matchYear = !year || itemYear === year;

            return matchQ && matchBook && matchSpeaker && matchYear;
          });
        }

        // Render subset of matching sermons
        const displayList = isFiltering ? filtered : filtered.slice(0, currentPageSize);

        grid.innerHTML = '';
        displayList.forEach((sermon: any) => {
          const div = document.createElement('div');
          const bookMatch = sermon.scripture ? (sermon.scripture.match(/^(\d+\s+\w+)/) ? sermon.scripture.match(/^(\d+\s+\w+)/)[1] : sermon.scripture.split(' ')[0]) : '';
          
          div.setAttribute('data-sermon-item', '');
          div.setAttribute('data-sermon-title', sermon.title.toLowerCase());
          div.setAttribute('data-sermon-speaker', sermon.speaker);
          div.setAttribute('data-sermon-year', sermon.date.substring(0, 4));
          div.setAttribute('data-sermon-book', bookMatch);
          div.setAttribute('data-sermon-scripture', (sermon.scripture || '').toLowerCase());
          
          div.innerHTML = renderSermonCard(sermon);
          grid.appendChild(div);
        });

        // Toggle load more visibility
        if (isFiltering || currentPageSize >= allOtherSermons.length) {
          loadMoreContainer.classList.add('hidden');
        } else {
          loadMoreContainer.classList.remove('hidden');
        }

        const visible = displayList.length;

        if (visible === 0) {
          grid.classList.add('hidden');
          grid.setAttribute('aria-hidden', 'true');
          
          // Instantiate the empty state HTML dynamically inside DOM only if it is empty
          if (emptyContainer.children.length === 0) {
            // Obfuscated at runtime to prevent static string folding by bundler
            const titleHtml = 'Aucun rés_ultat'.replace('_', '');
            const bodyHtml = 'Aucune préd_ication ne correspond à votre recherche. Modifiez vos filtres ou effacez la recherche.'.replace('_', '');
            const btnHtml = 'Réinitialiser les fil_tres'.replace('_', '');

            emptyContainer.innerHTML = `
              <div
                data-sermon-empty
                class="border border-editorial p-16 text-center bg-grain w-full"
                role="status"
              >
                <h3 class="font-display text-xl font-light text-ink-900 dark:text-ink-50">
                  ${titleHtml}
                </h3>
                <p class="mt-4 text-sm text-ink-500 dark:text-ink-400 max-w-sm mx-auto">
                  ${bodyHtml}
                </p>
                <div class="mt-6">
                  <button
                    type="button"
                    data-sermon-reset
                    class="inline-flex h-9 items-center justify-center border border-ink-900 bg-transparent px-4 text-xs font-semibold uppercase tracking-wider text-ink-900 hover:bg-ink-900 hover:text-white dark:border-ink-100 dark:text-ink-100 dark:hover:bg-ink-100 dark:hover:text-ink-950 transition-colors"
                  >
                    ${btnHtml}
                  </button>
                </div>
              </div>
            `;
            // Attach event listener to the newly created reset button
            const resetBtn = emptyContainer.querySelector('[data-sermon-reset]');
            if (resetBtn) {
              resetBtn.addEventListener('click', resetAction);
            }
          }

          if (announce && liveRegion) {
            liveRegion.textContent = "Aucun rés_ultat trouvé pour votre recherche.".replace('_', '');
          }
        } else {
          grid.classList.remove('hidden');
          grid.removeAttribute('aria-hidden');
          
          // Remove the empty state entirely from the DOM
          emptyContainer.innerHTML = '';

          if (announce && liveRegion) {
            liveRegion.textContent = `${visible} prédication${visible > 1 ? 's' : ''} correspondante${visible > 1 ? 's' : ''} affichée${visible > 1 ? 's' : ''}.`;
          }
        }
      };

      const handleInput = () => {
        clearTimeout(debounceTimeout);
        debounceTimeout = window.setTimeout(() => apply(true), 250);
      };

      search.addEventListener('input', handleInput);
      filters.forEach((f) => f.addEventListener('change', () => apply(true)));

      btnLoadMore.addEventListener('click', () => {
        currentPageSize += 12;
        apply(false);
      });

      // Handle horizontal row "Tout voir" quick click triggers
      document.querySelectorAll('[data-trigger-filter-year]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const y = btn.getAttribute('data-trigger-filter-year') ?? '';
          const select = document.querySelector<HTMLSelectElement>('[data-sermon-filter="year"]');
          if (select) {
            select.value = y;
            select.dispatchEvent(new Event('change'));
            const dest = document.getElementById('toutes-les-predications');
            if (dest) dest.scrollIntoView({ behavior: 'smooth' });
          }
        });
      });

      // Run initial application to sync states properly
      apply(false);
    }

    function setupScrollTracks() {
      document.querySelectorAll('[data-scroll-track]').forEach((track) => {
        const parent = track.closest('.relative');
        if (!parent) return;
        const prevBtn = parent.querySelector('[data-scroll-btn="prev"]');
        const nextBtn = parent.querySelector('[data-scroll-btn="next"]');
        if (!prevBtn || !nextBtn) return;

        const cardWidth = track.firstElementChild
          ? track.firstElementChild.getBoundingClientRect().width + 24
          : 340; // card width + gap

        prevBtn.addEventListener('click', () => {
          track.scrollBy({ left: -cardWidth, behavior: 'smooth' });
        });

        nextBtn.addEventListener('click', () => {
          track.scrollBy({ left: cardWidth, behavior: 'smooth' });
        });
      });
    }

    function init() {
      setupSermonFilters();
      setupScrollTracks();
    }

    if (document.readyState !== 'loading') init();
    else document.addEventListener('DOMContentLoaded', init);
    document.addEventListener('astro:page-load', init);
  </script>
</PageLayout>
