---
import PageLayout from '../../layouts/PageLayout.astro';
import Container from '../../components/Container.astro';
import Button from '../../components/Button.astro';
import SermonCard from '../../components/SermonCard.astro';
import {
  sermons,
  getFeaturedSermon,
  getAllSpeakers,
  getAllSeries,
} from '../../data/sermons.ts';
import { church } from '../../data/church.ts';

const featured = getFeaturedSermon();
const otherSermons = sermons.filter((s) => s.id !== featured.id);
const speakers = getAllSpeakers();
const series = getAllSeries();

// Année par année pour le filtre
const years = Array.from(
  new Set(sermons.map((s) => s.date.substring(0, 4)))
).sort((a, b) => b.localeCompare(a));

export const prerender = true;
---

<PageLayout
  title="Prédications — Enseignements bibliques en vidéo"
  description="Parcourez notre bibliothèque d'enseignements bibliques : vidéos de culte, thématiques de rentrée, et messages d'espérance."
  eyebrow="Bibliothèque"
  pageTitle="Toutes nos prédications"
  pageLead={`${sermons.length} enseignements à écouter en vidéo. Retrouvez ici nos messages dominicaux, classés par orateur, thème ou série biblique.`}
>
  <slot name="hero-extra">
    <div class="mt-8 flex flex-wrap gap-3">
      <Button
        href={church.social.youtube.sermonsPlaylist}
        variant="primary"
        size="md"
        external
        icon="youtube"
      >
        Playlist YouTube
      </Button>
      <Button
        href={church.social.youtube.channel}
        variant="secondary"
        size="md"
        external
      >
        Chaîne YouTube de l'église
      </Button>
    </div>
  </slot>

  <!-- ============ FEATURED SERMON SECTION ============ -->
  <section class="py-16 md:py-24 border-b border-editorial bg-grain">
    <Container size="default">
      <div class="mb-10">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-terracotta-700 dark:text-terracotta-300">
          À la une
        </p>
      </div>
      <SermonCard sermon={featured} featured={true} />
    </Container>
  </section>

  <!-- ============ FILTER BAR & GRID ============ -->
  <section class="py-16 md:py-24 bg-grain">
    <Container size="default">
      
      <!-- Custom Typographic Filter Bar (No rounded search box or templates) -->
      <div class="mb-16 flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between border-b border-editorial pb-10">
        
        <!-- Search Input -->
        <div class="w-full lg:max-w-md">
          <label for="sermon-search" class="sr-only">Rechercher une prédication</label>
          <div class="relative">
            <input
              type="search"
              id="sermon-search"
              placeholder="Rechercher par titre, texte biblique, orateur..."
              class="input-editorial pl-2 pr-10"
              data-sermon-search
            />
            <svg
              class="absolute right-3 top-1/2 h-4 w-4 -translate-y-1/2 text-ink-400"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="11" cy="11" r="8"></circle>
              <path d="m21 21-4.3-4.3"></path>
            </svg>
          </div>
        </div>

        <!-- Filter Selects -->
        <div class="flex flex-wrap gap-4">
          <select
            class="bg-transparent border-b border-editorial py-2.5 text-xs font-semibold uppercase tracking-wider text-ink-700 focus:outline-none focus:border-terracotta-500 dark:text-ink-300"
            data-sermon-filter="series"
            aria-label="Filtrer par série"
          >
            <option value="" class="dark:bg-ink-950">Toutes les séries</option>
            {series.map((s) => <option value={s} class="dark:bg-ink-950">{s}</option>)}
          </select>

          <select
            class="bg-transparent border-b border-editorial py-2.5 text-xs font-semibold uppercase tracking-wider text-ink-700 focus:outline-none focus:border-terracotta-500 dark:text-ink-300"
            data-sermon-filter="speaker"
            aria-label="Filtrer par prédicateur"
          >
            <option value="" class="dark:bg-ink-950">Tous les prédicateurs</option>
            {speakers.map((s) => <option value={s} class="dark:bg-ink-950">{s}</option>)}
          </select>

          <select
            class="bg-transparent border-b border-editorial py-2.5 text-xs font-semibold uppercase tracking-wider text-ink-700 focus:outline-none focus:border-terracotta-500 dark:text-ink-300"
            data-sermon-filter="year"
            aria-label="Filtrer par année"
          >
            <option value="" class="dark:bg-ink-950">Toutes les années</option>
            {years.map((y) => <option value={y} class="dark:bg-ink-950">{y}</option>)}
          </select>
        </div>
      </div>

      <!-- Empty State -->
      <div
        data-sermon-empty
        class="hidden border border-editorial p-16 text-center bg-grain"
      >
        <h3 class="font-display text-xl font-light text-ink-900 dark:text-ink-50">
          Aucun résultat
        </h3>
        <p class="mt-4 text-sm text-ink-500 dark:text-ink-400 max-w-sm mx-auto">
          Nous n'avons trouvé aucune prédication correspondant à ces critères. Essayez de simplifier votre recherche.
        </p>
      </div>

      <!-- Sermon Grid -->
      <div
        class="grid grid-cols-1 gap-x-8 gap-y-16 sm:grid-cols-2 lg:grid-cols-3"
        data-sermon-grid
      >
        {otherSermons.map((sermon) => (
          <div
            data-sermon-item
            data-sermon-title={sermon.title.toLowerCase()}
            data-sermon-speaker={sermon.speaker}
            data-sermon-series={sermon.series ?? ''}
            data-sermon-year={sermon.date.substring(0, 4)}
            data-sermon-scripture={sermon.scripture?.toLowerCase() ?? ''}
          >
            <SermonCard sermon={sermon} />
          </div>
        ))}
      </div>

    </Container>
  </section>

  <!-- JS search client-side script -->
  <script>
    function setupSermonFilters() {
      const search = document.querySelector<HTMLInputElement>(
        '[data-sermon-search]'
      );
      const filters = document.querySelectorAll<HTMLSelectElement>(
        '[data-sermon-filter]'
      );
      const items = document.querySelectorAll<HTMLElement>('[data-sermon-item]');
      const empty = document.querySelector<HTMLElement>('[data-sermon-empty]');
      const grid = document.querySelector<HTMLElement>('[data-sermon-grid]');
      if (!search || !empty || !grid) return;

      const apply = () => {
        const q = search.value.trim().toLowerCase();
        const series =
          (document.querySelector(
            '[data-sermon-filter="series"]'
          ) as HTMLSelectElement | null)?.value ?? '';
        const speaker =
          (document.querySelector(
            '[data-sermon-filter="speaker"]'
          ) as HTMLSelectElement | null)?.value ?? '';
        const year =
          (document.querySelector(
            '[data-sermon-filter="year"]'
          ) as HTMLSelectElement | null)?.value ?? '';

        let visible = 0;
        items.forEach((item) => {
          const title = item.dataset.sermonTitle ?? '';
          const itemSpeaker = item.dataset.sermonSpeaker ?? '';
          const itemSeries = item.dataset.sermonSeries ?? '';
          const itemYear = item.dataset.sermonYear ?? '';
          const scripture = item.dataset.sermonScripture ?? '';

          const matchQ =
            !q ||
            title.includes(q) ||
            itemSpeaker.toLowerCase().includes(q) ||
            itemSeries.toLowerCase().includes(q) ||
            scripture.includes(q);
          const matchSeries = !series || itemSeries === series;
          const matchSpeaker = !speaker || itemSpeaker === speaker;
          const matchYear = !year || itemYear === year;

          const show = matchQ && matchSeries && matchSpeaker && matchYear;
          item.style.display = show ? '' : 'none';
          if (show) visible++;
        });

        if (visible === 0) {
          grid.classList.add('hidden');
          empty.classList.remove('hidden');
        } else {
          grid.classList.remove('hidden');
          empty.classList.add('hidden');
        }
      };

      search.addEventListener('input', apply);
      filters.forEach((f) => f.addEventListener('change', apply));
    }

    if (document.readyState !== 'loading') setupSermonFilters();
    else document.addEventListener('DOMContentLoaded', setupSermonFilters);
    document.addEventListener('astro:page-load', setupSermonFilters);
  </script>
</PageLayout>
