---
import PageLayout from '../layouts/PageLayout.astro';
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
import {
  activities,
  activityTestimonies,
} from '../data/activities.ts';

const sundayActivities = activities.filter(
  (a) => a.category === 'dimanche' || a.category === 'famille'
);

const weeklyActivities = activities.filter(
  (a) => a.category === 'semaine'
);

const youthActivities = activities.filter(
  (a) => a.category === 'jeunes'
);

const bibleActivities = activities.filter(
  (a) => a.category === 'biblique'
);

const bibleTestimonies = activityTestimonies.filter(
  (t) => t.activityId === 'bible-en-1-an'
);

export const prerender = true;
---

<PageLayout
  title="Activités — Notre vie communautaire toute la semaine"
  description="Cultes, école du dimanche, groupes de quartier, étude de la Bible, repas partagés... Découvrez tous les rendez-vous réguliers de l'EEB Massy."
  eyebrow="Vie communautaire"
  pageTitle="Nos activités"
  pageLead="La vie de notre église ne se limite pas au dimanche matin. Découvrez les différents moments de rencontre, d'apprentissage et de fraternité qui rythment nos semaines."
>

  <!-- ============ SECTION 1: LE DIMANCHE (CHRONOLOGICAL FLOW) ============ -->
  <section class="py-20 md:py-24 border-b border-editorial bg-grain">
    <Container size="default">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">
        
        <!-- Left Title (4 cols) -->
        <div class="lg:col-span-4 lg:sticky lg:top-24 self-start">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-terracotta-700 dark:text-terracotta-300">
            Dimanche aux Cèdres
          </p>
          <h2 class="mt-4 font-display text-4xl font-light leading-[1.05] tracking-tight text-ink-900 dark:text-ink-50 sm:text-5xl">
            Le dimanche matin
          </h2>
          <p class="mt-6 text-sm leading-relaxed text-ink-600 dark:text-ink-400 editorial-indent">
            Le dimanche est notre temps fort hebdomadaire. Toutes les tranches d'âge s'y retrouvent pour célébrer et grandir ensemble.
          </p>
          <div class="mt-8">
            <Button href="/premiere-visite" variant="primary" size="md">
              Préparer ma venue
            </Button>
          </div>
        </div>

        <!-- Chronological Timeline Items (8 cols) -->
        <div class="lg:col-span-8 border-t border-editorial">
          <div class="divide-y divide-editorial">
            {sundayActivities.map((act) => (
              <div class="py-8 grid grid-cols-1 sm:grid-cols-12 sm:gap-8">
                <div class="sm:col-span-3">
                  <span class="text-xs font-semibold uppercase tracking-wider text-terracotta-700 dark:text-terracotta-300">
                    {act.schedule}
                  </span>
                </div>
                <div class="sm:col-span-9 mt-2 sm:mt-0">
                  <h3 class="font-display text-lg font-medium text-ink-900 dark:text-ink-50">
                    {act.title}
                  </h3>
                  <p class="mt-2 text-sm leading-relaxed text-ink-600 dark:text-ink-400">
                    {act.description}
                  </p>
                  <div class="mt-4 flex flex-wrap gap-4 text-xs text-ink-400 dark:text-ink-500 uppercase tracking-wider">
                    <span>✦ Public : {act.audience}</span>
                    {act.location && <span>✦ Lieu : {act.location.split(',')[0]}</span>}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </Container>
  </section>

  <!-- ============ SECTION 2: EN SEMAINE (NEIGHBORHOOD GROUPS) ============ -->
  <section class="py-20 md:py-28 border-b border-editorial bg-grain">
    <Container size="default">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16 items-start">
        
        <!-- Description block (7 cols) -->
        <div class="lg:col-span-7">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-terracotta-700 dark:text-terracotta-300">
            Groupes de quartier
          </p>
          <h2 class="mt-4 font-display text-4xl font-light leading-[1.05] tracking-tight text-ink-900 dark:text-ink-50 sm:text-5xl">
            Tisser des liens fraternels dans les environs
          </h2>
          <p class="mt-6 text-base leading-relaxed text-ink-700 dark:text-ink-300 editorial-indent">
            En milieu de semaine, la vie communautaire continue dans des petits groupes de <strong class="font-medium">8 à 12 personnes</strong>, hébergés dans les foyers de membres. Ces groupes se réunissent à Massy, Palaiseau, Antony, Wissous ou Igny pour prier, partager et étudier ensemble la Bible de manière simple et amicale.
          </p>
          <div class="mt-8">
            <Button href="/groupes" variant="primary" size="md">
              Voir la carte des groupes
            </Button>
          </div>
        </div>

        <!-- Asymmetric text summary table (Right 5 cols) -->
        <div class="lg:col-span-5 lg:border-l border-editorial lg:pl-10 lg:mt-6">
          <h3 class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-900 dark:text-ink-50 border-b border-editorial pb-3">
            Jours et Horaires des Groupes
          </h3>
          <ul class="mt-6 space-y-4 text-sm">
            <li class="flex items-center gap-3 border-b border-editorial-subtle pb-3">
              <span class="h-1.5 w-1.5 bg-sage-500 rounded-none" />
              <span class="font-medium text-ink-850 dark:text-ink-150">Mercredi :</span> 20h00
            </li>
            <li class="flex items-center gap-3 border-b border-editorial-subtle pb-3">
              <span class="h-1.5 w-1.5 bg-sage-500 rounded-none" />
              <span class="font-medium text-ink-850 dark:text-ink-150">Jeudi :</span> 20h30
            </li>
            <li class="flex items-center gap-3">
              <span class="h-1.5 w-1.5 bg-sage-500 rounded-none" />
              <span class="font-medium text-ink-850 dark:text-ink-150">Vendredi :</span> 20h00
            </li>
          </ul>
        </div>

      </div>
    </Container>
  </section>

  <!-- ============ SECTION 3: LES JEUNES ============ -->
  {youthActivities.map((youth) => (
    <section class="py-20 border-b border-editorial bg-grain">
      <Container size="default">
        <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16 items-start">
          
          <!-- Large typography age accent (Left 4 cols) -->
          <div class="lg:col-span-4 border-t border-editorial pt-6">
            <span class="text-xs uppercase tracking-[0.2em] text-terracotta-700 dark:text-terracotta-300">
              Groupe Ado / Lycée
            </span>
            <p class="mt-4 font-display text-7xl font-light text-ink-900 dark:text-ink-50">
              15 · 20
            </p>
            <p class="text-xs uppercase tracking-wider text-ink-400 dark:text-ink-500 font-semibold mt-1">
              ans
            </p>
          </div>

          <!-- Content block (8 cols) -->
          <div class="lg:col-span-8 border-t border-editorial pt-6">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-terracotta-700 dark:text-terracotta-300">
              {youth.schedule}
            </p>
            <h2 class="mt-3 font-display text-3xl font-light tracking-tight text-ink-900 dark:text-ink-50 sm:text-4xl">
              {youth.title}
            </h2>
            <p class="mt-6 text-base leading-relaxed text-ink-700 dark:text-ink-300 editorial-indent">
              {youth.description}
            </p>
            <p class="mt-3 text-xs text-ink-500 dark:text-ink-400 uppercase tracking-wider">
              ✦ Lieu : {youth.location}
            </p>
            <div class="mt-8">
              <Button href="/contact" variant="secondary" size="md">
                Contacter les animateurs
              </Button>
            </div>
          </div>

        </div>
      </Container>
    </section>
  ))}

  <!-- ============ SECTION 4: BIBLE ET TÉMOIGNAGES (FLAT QUOTES) ============ -->
  {bibleActivities.map((bible) => (
    <section class="py-20 bg-grain">
      <Container size="default">
        <div class="space-y-16">
          
          <!-- Description Block -->
          <div class="max-w-3xl">
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-sage-700 dark:text-sage-300">
              Étude & Brunch
            </p>
            <h2 class="mt-3 font-display text-4xl font-light leading-[1.05] tracking-tight text-ink-900 dark:text-ink-50 sm:text-5xl">
              {bible.title}
            </h2>
            <p class="mt-6 text-base leading-relaxed text-ink-700 dark:text-ink-300 editorial-indent">
              {bible.description}
            </p>
            <p class="mt-3 text-xs text-ink-500 dark:text-ink-400 uppercase tracking-wider">
              ✦ Horaires : {bible.schedule}
            </p>
          </div>

          <!-- Testimonies Carousel/Grid of Quotes -->
          {bibleTestimonies.length > 0 && (
            <div class="pt-12 border-t border-editorial">
              <h3 class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-900 dark:text-ink-50 mb-10">
                Témoignages des lecteurs
              </h3>
              
              <div class="grid grid-cols-1 gap-12 md:grid-cols-3">
                {bibleTestimonies.map((test) => (
                  <div class="flex flex-col justify-between border-l border-editorial-subtle pl-6">
                    <blockquote class="font-display italic text-base leading-relaxed text-ink-700 dark:text-ink-300">
                      « {test.text} »
                    </blockquote>
                    <div class="mt-6">
                      <cite class="not-italic text-xs font-semibold uppercase tracking-wider text-ink-900 dark:text-ink-50">
                        {test.name}
                      </cite>
                      <p class="text-[10px] text-ink-400 dark:text-ink-500 uppercase tracking-wider mt-0.5">
                        Lecteur régulier
                      </p>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

        </div>
      </Container>
    </section>
  ))}

  <!-- CTA -->
  <section class="py-24 border-t border-editorial bg-sand-50/50 dark:bg-ink-950/40">
    <Container size="narrow" class="text-center">
      <h2 class="font-display text-4xl font-light text-ink-900 dark:text-ink-50">
        Une question sur nos rencontres ?
      </h2>
      <p class="mt-4 text-base text-ink-600 dark:text-ink-300 max-w-lg mx-auto">
        Que vous souhaitiez nous rejoindre un dimanche matin, poser une question ou passer découvrir un groupe, nous serons ravis de vous guider.
      </p>
      <div class="mt-10 flex justify-center gap-4">
        <Button href="/contact" variant="primary" size="lg">
          Nous écrire
        </Button>
        <Button href="/premiere-visite" variant="secondary" size="lg">
          Découvrir le culte
        </Button>
      </div>
    </Container>
  </section>

</PageLayout>
