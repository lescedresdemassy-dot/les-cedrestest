---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
import { church } from '../data/church.ts';
import { getFeaturedSermon } from '../data/sermons.ts';
import { getHighlightActivities } from '../data/activities.ts';

const featured = getFeaturedSermon();
const highlights = getHighlightActivities();

// Prochain dimanche (calculé côté serveur)
const today = new Date();
const daysUntilSunday = (7 - today.getDay()) % 7 || 7;
const nextSunday = new Date(today);
nextSunday.setDate(today.getDate() + daysUntilSunday);
const nextSundayFormatted = nextSunday.toLocaleDateString('fr-FR', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
});

// YouTube thumbnail details
const featuredThumbnail = `https://i.ytimg.com/vi/${featured.youtubeId}/maxresdefault.jpg`;
const featuredFallback = `https://i.ytimg.com/vi/${featured.youtubeId}/hqdefault.jpg`;

export const prerender = true;
---

<BaseLayout
  title={`${church.name} — Une communauté ouverte à Massy`}
  description={church.description}
  schema="organization"
>
  <!-- ===================================================================== -->
  <!-- HERO: MONOGRAPH COVER -->
  <!-- ===================================================================== -->
  <section class="relative pt-10 pb-12 border-b border-editorial bg-grain sm:pt-16 sm:pb-16 lg:pt-20 lg:pb-20">
    <Container size="default">
      
      <!-- Top meta line -->
      <div class="mb-6 flex items-center gap-3 text-[10px] uppercase tracking-[0.25em] text-terracotta-700 dark:text-terracotta-300">
        <span class="h-1.5 w-1.5 bg-terracotta-600 dark:bg-terracotta-400"></span>
        <span>Prochain culte · {nextSundayFormatted} à 10 h 30</span>
      </div>

      <div class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-16">
        
        <!-- Giant Typographic statement (Left 9 cols) -->
        <div class="lg:col-span-9">
          <h1 class="font-display text-5xl font-light leading-[0.9] tracking-tight text-ink-900 dark:text-ink-50 sm:text-7xl md:text-8xl lg:text-[5.5rem] xl:text-[6.5rem]">
            Une communauté <br />
            <span class="font-medium italic text-terracotta-700 dark:text-terracotta-300">ouverte & vivante</span> <br />
            à Massy.
          </h1>
          
          <div class="mt-6 max-w-2xl">
            <p class="text-base leading-relaxed text-ink-600 dark:text-ink-300 sm:text-lg editorial-indent">
              L'Église Évangélique Baptiste de Massy accueille tous ceux qui souhaitent découvrir ou approfondir la foi chrétienne. Au Centre Les Cèdres, plus de <strong class="font-medium text-ink-900 dark:text-ink-50">{church.history.nationalities} nationalités</strong> partagent une foi simple et une vie fraternelle ancrée dans la Bible.
            </p>
          </div>

          <div class="mt-8 flex flex-wrap gap-4">
            <Button href="/premiere-visite" variant="primary" size="lg" icon="arrow">
              Préparer ma première visite
            </Button>
            <Button href="/contact" variant="secondary" size="lg">
              Nous contacter
            </Button>
          </div>
        </div>

        <!-- Asymmetric columns (Right 3 cols) -->
        <div class="lg:col-span-3 flex flex-col justify-start lg:border-l border-editorial lg:pl-10">
          <div class="space-y-8 text-[10px] uppercase tracking-[0.18em] text-ink-500 dark:text-ink-400">
            <div>
              <p class="font-semibold text-ink-900 dark:text-ink-50 mb-1.5">Culte dominical</p>
              <p class="normal-case tracking-normal text-sm text-ink-600 dark:text-ink-400">Tous les dimanches à 10 h 30. Entrée libre.</p>
            </div>
            
            <div class="border-t border-editorial pt-6">
              <p class="font-semibold text-ink-900 dark:text-ink-50 mb-1.5">Adresse</p>
              <p class="normal-case tracking-normal text-sm text-ink-600 dark:text-ink-400">{church.address.street}<br/>{church.address.postalCode} {church.address.city}</p>
            </div>

            <div class="border-t border-editorial pt-6">
              <p class="font-semibold text-ink-900 dark:text-ink-50 mb-1.5">Affiliations</p>
              <p class="normal-case tracking-normal text-sm text-ink-600 dark:text-ink-400">Membre FEEBF · CNEF · FPF</p>
            </div>
          </div>
        </div>

      </div>
    </Container>
  </section>

  <!-- ===================================================================== -->
  <!-- NARRATIVE: THE SUNDAY FLOW -->
  <!-- ===================================================================== -->
  <section class="py-24 border-b border-editorial bg-grain">
    <Container size="default">
      <div class="grid grid-cols-1 gap-16 lg:grid-cols-12 lg:gap-16">
        
        <!-- Left details (4 cols) -->
        <div class="lg:col-span-4 lg:sticky lg:top-24 self-start">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-terracotta-700 dark:text-terracotta-300">
            Le dimanche matin
          </p>
          <h2 class="mt-4 font-display text-4xl font-light leading-[1.05] tracking-tight text-ink-900 dark:text-ink-50 sm:text-5xl">
            Déroulement du culte
          </h2>
          <p class="mt-6 text-sm leading-relaxed text-ink-600 dark:text-ink-400 editorial-indent">
            Notre culte hebdomadaire est un moment sobre et chaleureux. Nous lisons la Bible, prions, chantons des cantiques classiques et des chants récents, et écoutons un message d'encouragement pratique pour nos vies.
          </p>
          <div class="mt-8">
            <a href="/premiere-visite" class="link-editorial-accent text-xs font-semibold uppercase tracking-wider">
              En savoir plus sur le culte →
            </a>
          </div>
        </div>

        <!-- Right Timeline steps (8 cols) -->
        <div class="lg:col-span-8 border-t border-editorial">
          <div class="divide-y divide-editorial">
            {[
              { time: '10 h 15', title: 'Accueil', desc: 'Ouverture des portes.' },
              { time: '10 h 30', title: 'Culte', desc: 'Prières, chants et prédication.' },
              { time: '11 h 00', title: 'Partages pour enfants', desc: 'Groupes d\'âge adaptés (3 à 15 ans).' },
              { time: '12 h 00', title: 'Café & Échanges', desc: 'Temps de convivialité dans le hall.' }
            ].map((step) => (
              <div class="grid grid-cols-1 py-6 sm:grid-cols-12 sm:gap-8">
                <div class="sm:col-span-3">
                  <span class="font-display text-2xl font-light text-terracotta-600 dark:text-terracotta-400">{step.time}</span>
                </div>
                <div class="sm:col-span-9 mt-1 sm:mt-0">
                  <h3 class="font-display text-base font-medium text-ink-900 dark:text-ink-50">{step.title}</h3>
                  <p class="mt-1 text-sm leading-relaxed text-ink-600 dark:text-ink-400">{step.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </Container>
  </section>

  <!-- ===================================================================== -->
  <!-- DNA QUOTE & ESSAY LINK -->
  <!-- ===================================================================== -->
  <section class="py-24 border-b border-editorial bg-grain">
    <Container size="default">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">
        
        <div class="lg:col-span-5">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-terracotta-700 dark:text-terracotta-300">
            Notre identité
          </p>
          <h2 class="mt-4 font-display text-4xl font-light leading-[1.05] tracking-tight text-ink-900 dark:text-ink-50 sm:text-5xl">
            Une église au milieu de la cité
          </h2>
          <p class="mt-6 text-sm leading-relaxed text-ink-600 dark:text-ink-400 editorial-indent">
            Héritiers du christianisme historique et des grands principes de la Réforme protestante, nous partageons une vision ouverte et attentive de la vie locale. 
          </p>
          <div class="mt-8">
            <a href="/notre-adn" class="link-editorial text-xs font-semibold uppercase tracking-wider">
              Découvrir nos repères & croyances →
            </a>
          </div>
        </div>

        <div class="lg:col-span-7 flex flex-col justify-end lg:border-l border-editorial lg:pl-12">
          <blockquote class="font-display italic text-xl leading-relaxed text-ink-800 dark:text-ink-200">
            « Nous cherchons à vivre de manière conforme à l'Évangile. Pour nous, la Bible est un guide vivant pour apprendre à aimer Dieu et notre prochain concrètement dans la cité. »
          </blockquote>
          <p class="mt-4 text-[10px] uppercase tracking-wider text-ink-400 dark:text-ink-500">
            — Notre projet de foi
          </p>
        </div>

      </div>
    </Container>
  </section>

  <!-- ===================================================================== -->
  <!-- ACTIVITIES (TABULAR ROWS) -->
  <!-- ===================================================================== -->
  <section class="py-24 border-b border-editorial bg-grain">
    <Container size="default">
      
      <div class="mb-16 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-terracotta-700 dark:text-terracotta-300">
            La vie en commun
          </p>
          <h2 class="mt-3 font-display text-4xl font-light leading-[1.05] tracking-tight text-ink-900 dark:text-ink-50 sm:text-5xl">
            Moments et partages réguliers
          </h2>
        </div>
        <a href="/activites" class="link-editorial text-xs font-semibold uppercase tracking-wider">
          Toutes nos activités →
        </a>
      </div>

      <!-- Tabular list representation (Zero Cards) -->
      <div class="border-t border-editorial divide-y divide-editorial">
        {highlights.map((activity, idx) => (
          <div class="grid grid-cols-1 gap-4 py-8 sm:grid-cols-12 sm:gap-8 items-center">
            
            <!-- Index & Day (3 cols) -->
            <div class="sm:col-span-3 flex items-baseline gap-3">
              <div>
                <h3 class="font-display text-lg font-medium text-ink-900 dark:text-ink-50">
                  {activity.title}
                </h3>
                <span class="text-xs font-semibold uppercase tracking-wider text-terracotta-700 dark:text-terracotta-400 block mt-1">
                  {activity.schedule}
                </span>
              </div>
            </div>

            <!-- Description (7 cols) -->
            <div class="sm:col-span-7">
              <p class="text-sm leading-relaxed text-ink-600 dark:text-ink-400">
                {activity.description}
              </p>
            </div>

            <!-- Audience (2 cols) -->
            <div class="sm:col-span-2 sm:text-right">
              <span class="text-xs uppercase tracking-wider text-ink-400 dark:text-ink-500 font-medium">
                {activity.audience.split('—')[0]}
              </span>
            </div>

          </div>
        ))}
      </div>

    </Container>
  </section>

  <!-- ===================================================================== -->
  <!-- FEATURED SERMON (BORDERLESS SPLIT JOURNAL LAYOUT) -->
  <!-- ===================================================================== -->
  <section class="py-24 border-b border-editorial bg-grain">
    <Container size="default">
      
      <div class="mb-16 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-terracotta-700 dark:text-terracotta-300">
            Dernier message
          </p>
          <h2 class="mt-3 font-display text-4xl font-light leading-[1.05] tracking-tight text-ink-900 dark:text-ink-50 sm:text-5xl">
            Prédication à l'écoute
          </h2>
        </div>
        <a href="/sermons" class="link-editorial text-xs font-semibold uppercase tracking-wider">
          Accéder à la bibliothèque d'enseignements →
        </a>
      </div>

      <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16 items-center">
        <!-- Thumbnail (Left 7 cols) -->
        <a href={`/sermons/${featured.id}`} class="relative block aspect-video w-full bg-sand-100 dark:bg-ink-800 lg:col-span-7 border border-editorial" aria-label={`Écouter : ${featured.title}`}>
          <img
            src={featuredThumbnail}
            onerror={`this.onerror=null;this.src='${featuredFallback}';`}
            alt=""
            loading="lazy"
            class="absolute inset-0 h-full w-full object-cover"
          />
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="flex h-14 w-14 items-center justify-center bg-ink-900 text-white dark:bg-ink-100 dark:text-ink-950" aria-hidden="true">
              <svg class="ml-0.5 h-5 w-5" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"></path></svg>
            </span>
          </div>
          {featured.durationMinutes && (
            <span class="absolute bottom-4 right-4 bg-ink-950/80 px-2.5 py-0.5 text-[10px] font-semibold text-white tracking-wide">
              {featured.durationMinutes >= 60 
                ? `${Math.floor(featured.durationMinutes / 60)} h ${String(featured.durationMinutes % 60).padStart(2, '0')}`
                : `${featured.durationMinutes} min`}
            </span>
          )}
        </a>

        <!-- Content details (Right 5 cols) -->
        <div class="lg:col-span-5 flex flex-col justify-center">
          <div class="flex items-center gap-2.5 text-xs text-ink-500 dark:text-ink-400 uppercase tracking-wider">
            <time datetime={featured.date}>
              {new Date(featured.date).toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
            </time>
            {featured.scripture && (
              <>
                <span>·</span>
                <span class="font-medium text-terracotta-700 dark:text-terracotta-300">{featured.scripture}</span>
              </>
            )}
          </div>

          <h3 class="mt-4 font-display text-2xl font-light leading-snug tracking-tight text-ink-900 dark:text-ink-50 sm:text-3xl lg:text-4xl">
            <a href={`/sermons/${featured.id}`} class="hover:text-terracotta-700 dark:hover:text-terracotta-300 transition-colors">
              {featured.title}
            </a>
          </h3>

          <p class="mt-3 text-xs text-ink-500 dark:text-ink-400">
            Par {featured.speaker} {featured.series ? `(série ${featured.series})` : ''}
          </p>

          {featured.description && (
            <p class="mt-4 text-sm leading-relaxed text-ink-750 dark:text-ink-300">
              {featured.description}
            </p>
          )}

          <div class="mt-8">
            <Button href={`/sermons/${featured.id}`} variant="primary" size="md">
              Écouter la prédication
            </Button>
          </div>
        </div>
      </div>

    </Container>
  </section>

  <!-- ===================================================================== -->
  <!-- GEOGRAPHIC & CONTACT ACCENT -->
  <!-- ===================================================================== -->
  <section class="py-24 bg-grain">
    <Container size="default">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">
        
        <!-- Address & Transports (Left 5 cols) -->
        <div class="lg:col-span-5 flex flex-col justify-center">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-terracotta-700 dark:text-terracotta-300">
            Nous localiser
          </p>
          <h2 class="mt-4 font-display text-4xl font-light leading-[1.05] tracking-tight text-ink-900 dark:text-ink-50 sm:text-5xl">
            Venir au Centre Les Cèdres
          </h2>
          
          <div class="mt-8 space-y-6 text-sm text-ink-700 dark:text-ink-300">
            <div>
              <p class="font-semibold text-ink-900 dark:text-ink-50">Adresse postale :</p>
              <p class="mt-1">{church.address.full}</p>
            </div>
            
            <div class="border-t border-editorial pt-4">
              <p class="font-semibold text-ink-900 dark:text-ink-50">Ligne de bus le dimanche :</p>
              <p class="mt-1">{church.transport.sunday}</p>
            </div>

            <div class="border-t border-editorial pt-4">
              <p class="font-semibold text-ink-900 dark:text-ink-50">Ligne de bus en semaine :</p>
              <p class="mt-1">{church.transport.weekday}</p>
            </div>
          </div>

          <div class="mt-8 flex flex-wrap gap-4">
            <Button href={church.address.googleMapsDirections} variant="primary" size="md" external>
              Calculer mon itinéraire
            </Button>
            <Button href="/contact" variant="secondary" size="md">
              Demander de l'aide
            </Button>
          </div>
        </div>

        <!-- Asymmetric iframe map frame (Right 7 cols) -->
        <div class="lg:col-span-7">
          <div class="overflow-hidden border border-editorial">
            <iframe
              src={church.address.googleMapsEmbed}
              width="100%"
              height="440"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Plan d'accès de l'EEB Massy"
              class="block"
            ></iframe>
          </div>
        </div>

      </div>
    </Container>
  </section>

  <!-- ===================================================================== -->
  <!-- CTA FOLD (SOBRE, ELEGANT) -->
  <!-- ===================================================================== -->
  <section class="border-t border-editorial bg-sand-50/50 py-24 dark:bg-ink-950/40">
    <Container size="narrow" class="text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-terracotta-700 dark:text-terracotta-300">
        Rencontre & Échanges
      </p>
      <h2 class="mt-4 font-display text-4xl font-light leading-[1.05] tracking-tight text-ink-900 dark:text-ink-50 sm:text-5xl">
        Une question ou un message ?
      </h2>
      <p class="mt-6 text-base leading-relaxed text-ink-600 dark:text-ink-300 max-w-xl mx-auto">
        Que vous habitiez la région, que vous soyez de passage ou simplement curieux d'en savoir plus sur la foi chrétienne, nous serons ravis d'entrer en contact avec vous.
      </p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <Button href="/contact" variant="primary" size="lg">
          Nous écrire un message
        </Button>
        <Button href={`tel:${church.contact.phoneE164}`} variant="secondary" size="lg">
          Appeler au {church.contact.phone}
        </Button>
      </div>
    </Container>
  </section>
</BaseLayout>
