---
import PageLayout from '../layouts/PageLayout.astro';
import Container from '../components/Container.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Button from '../components/Button.astro';
import { church } from '../data/church.ts';

const pillars = [
  {
    id: 'chretiens',
    label: 'Chrétiens',
    title: 'Héritiers d\'une foi millénaire',
    description: church.identity.chretiens,
    detail:
      'Notre identité puise ses racines dans l\'héritage transmis par tous ceux qui rendent témoignage depuis deux mille ans au Christ ressuscité, dans la soumission au Dieu éternel.',
    icon: 'cross',
  },
  {
    id: 'protestants',
    label: 'Protestants',
    title: 'Les grands principes de la Réforme',
    description: church.identity.protestants,
    detail:
      'Le Christ seul, médiateur entre Dieu et les hommes. L\'Écriture seule, autorité ultime. La foi seule, pour le salut. La grâce seule, comme don. À Dieu seul, la gloire.',
    icon: 'sparkles',
  },
  {
    id: 'evangeliques',
    label: 'Évangéliques',
    title: 'Vivre selon l\'Évangile',
    description: church.identity.evangeliques,
    detail:
      'Nous cherchons à vivre conformément à l\'Évangile. La Bible est, pour le croyant, la seule norme à laquelle se référer — un guide pratique pour aimer Dieu et son prochain.',
    icon: 'book',
  },
  {
    id: 'baptistes',
    label: 'Baptistes',
    title: 'Une église de professants',
    description: church.identity.baptistes,
    detail:
      'Le baptisme se définit comme un mouvement d\'Églises de professants : chacun, conscient de sa foi personnelle en Jésus-Christ, demande à être baptisé. Une communauté qui repose sur l\'engagement libre et éclairé.',
    icon: 'water',
  },
];

const iconSvgs: Record<string, string> = {
  cross: '<path d="M11 2h2v8h8v2h-8v10h-2V12H3v-2h8z"/>',
  sparkles: '<path d="M12 3l1.9 5.5L19 10.4l-5.1 1.9L12 17.8l-1.9-5.5L5 10.4l5.1-1.9z"/><path d="M19 14l.9 2.5L22 17.4l-2.1.9L19 20.8l-.9-2.5L16 17.4l2.1-.9z"/><path d="M5 4l.9 2.5L8 7.4l-2.1.9L5 10.8l-.9-2.5L2 7.4l2.1-.9z"/>',
  book: '<path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>',
  water: '<path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/>',
};

export const prerender = true;
---

<PageLayout
  title="Notre ADN — Qui sommes-nous ?"
  description="Notre identité confessionnelle : chrétiens, protestants, évangéliques, baptistes. Une foi enracinée dans la Bible, ouverte à tous."
  eyebrow="Notre ADN"
  pageTitle="Qui sommes-nous ?"
  pageLead="L'Église Évangélique Baptiste de Massy s'inscrit dans la continuité de la foi chrétienne universelle. Notre vie de communauté s'articule autour de principes clairs, vécus dans le respect et l'accueil."
>
  <!-- Intro & Confession (Asymmetric 2-column) -->
  <section class="py-20 md:py-24 border-b border-editorial bg-grain">
    <Container size="default">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">
        
        <!-- Left: Text block -->
        <div class="lg:col-span-8 prose max-w-prose text-ink-700 dark:text-ink-300">
          <p class="text-lg leading-relaxed text-pretty">
            Les Églises évangéliques baptistes existent <strong class="text-ink-900 dark:text-ink-50 font-medium">depuis 1609</strong> dans le monde, et <strong class="text-ink-900 dark:text-ink-50 font-medium">depuis 1820 en France</strong>. Elles partagent avec les autres églises protestantes et évangéliques la certitude que l'amour de Dieu manifesté en Jésus-Christ est accessible à chacun.
          </p>
          <p class="mt-6 text-lg leading-relaxed text-pretty">
            Nous considérons que la foi est un choix personnel et conscient. C'est pourquoi nous accueillons toute personne désireuse d'explorer la foi ou simplement de visiter, sans aucune obligation d'appartenance.
          </p>
          <p class="mt-6 text-lg leading-relaxed text-pretty">
            Nos rencontres régulières et nos programmes sont ouverts à tous, croyants ou en recherche. Nous croyons que la foi grandit au travers de discussions libres, honnêtes et fraternelles.
          </p>
        </div>

        <!-- Right: Confession List (Borderless) -->
        <div class="lg:col-span-4 flex items-center lg:border-l border-editorial lg:pl-10">
          <div class="w-full">
            <h3 class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-900 dark:text-ink-50 border-b border-editorial pb-3">
              Confession de foi
            </h3>
            <p class="mt-4 text-xs text-ink-500 dark:text-ink-400">
              Nos convictions reposent sur l'autorité des Écritures bibliques.
            </p>
            <ul class="mt-6 space-y-4">
              {pillars.map((p) => (
                <li class="flex items-center gap-3">
                  <span class="flex h-5 w-5 items-center justify-center bg-terracotta-100 text-terracotta-700 dark:bg-terracotta-950/40 dark:text-terracotta-300 rounded-none">
                    <svg class="h-3 w-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={iconSvgs[p.icon]} />
                  </span>
                  <a href={`#${p.id}`} class="text-xs font-semibold uppercase tracking-wider text-ink-800 hover:text-terracotta-700 dark:text-ink-200 dark:hover:text-terracotta-300 transition-colors">
                    {p.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </div>

      </div>
    </Container>
  </section>

  <!-- Four Pillars — Typographic essay -->
  <section class="py-24 border-b border-editorial bg-grain">
    <Container size="default">
      <SectionHeading
        eyebrow="Fondements"
        title="Une identité en quatre piliers"
        lead="Voici comment s'articulent nos convictions confessionnelles et historiques."
        class="mb-20"
      />

      <div class="space-y-24 lg:space-y-36">
        {pillars.map((p, i) => (
          <article id={p.id} class="grid grid-cols-1 gap-8 lg:grid-cols-12 lg:gap-16 items-start">
            
            <!-- Number index (Left 3 cols) -->
            <div class="lg:col-span-3">
              <span class="font-display text-5xl font-light text-terracotta-600 dark:text-terracotta-400">
                0{i + 1}
              </span>
              <p class="mt-2 text-xs font-semibold uppercase tracking-[0.2em] text-ink-900 dark:text-ink-50">
                {p.label}
              </p>
            </div>

            <!-- Content (Right 9 cols) -->
            <div class="lg:col-span-9 border-t border-editorial pt-6">
              <h3 class="font-display text-3xl font-light tracking-tight text-ink-900 dark:text-ink-50 sm:text-4xl">
                {p.title}
              </h3>
              <p class="mt-6 text-lg leading-relaxed text-ink-700 dark:text-ink-300 text-pretty">
                {p.description}
              </p>
              <p class="mt-4 text-base leading-relaxed text-ink-600 dark:text-ink-400 text-pretty">
                {p.detail}
              </p>
            </div>

          </article>
        ))}
      </div>
    </Container>
  </section>

  <!-- History & Timeline (Asymmetric vertical layout) -->
  <section class="py-24 border-b border-editorial bg-grain">
    <Container size="default">
      <div class="grid grid-cols-1 gap-12 lg:grid-cols-12 lg:gap-16">
        
        <!-- Title and context (Left 5 cols) -->
        <div class="lg:col-span-5 flex flex-col justify-start">
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-terracotta-700 dark:text-terracotta-300">
            Origines & Histoire
          </p>
          <h2 class="mt-4 font-display text-4xl font-light leading-[1.05] tracking-tight text-ink-900 dark:text-ink-50 sm:text-5xl">
            L'histoire des Cèdres à Massy
          </h2>
          <p class="mt-6 text-sm leading-relaxed text-ink-700 dark:text-ink-300 editorial-indent">
            Notre église est hébergée par le Centre Évangélique <em>Les Cèdres</em> (Recherches, Entraide et Service), ainsi nommé pour les cèdres historiques qui ornent son parc.
          </p>
        </div>

        <!-- Timeline steps (Right 7 cols) -->
        <div class="lg:col-span-7 border-t border-editorial">
          <div class="divide-y divide-editorial">
            {[
              { year: '1971', title: 'Construction du Centre Les Cèdres', desc: 'Édification du bâtiment pour héberger nos cultes et les œuvres sociales de la région.' },
              { year: '1972', title: 'Premiers cultes', desc: 'Début officiel de la vie communautaire régulière.' },
              { year: '2001', title: 'Rénovation de la chapelle', desc: 'Agrandissement de la salle principale à 140 places.' },
              { year: '2011', title: 'Introduction de deux services', desc: 'Proposition de deux créneaux consécutifs pour répondre à la croissance de l\'affluence.' },
              { year: 'Aujourd\'hui', title: 'Une fraternité vivante', desc: `Une communauté cosmopolite réunissant plus de ${church.history.nationalities} nationalités le dimanche matin.` }
            ].map((step) => (
              <div class="grid grid-cols-1 py-8 sm:grid-cols-12 sm:gap-8">
                <div class="sm:col-span-3">
                  <span class="font-display text-2xl font-light text-terracotta-600 dark:text-terracotta-400">{step.year}</span>
                </div>
                <div class="sm:col-span-9 mt-2 sm:mt-0">
                  <h3 class="font-display text-base font-semibold text-ink-900 dark:text-ink-50">{step.title}</h3>
                  <p class="mt-1 text-sm leading-relaxed text-ink-600 dark:text-ink-400">{step.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </Container>
  </section>

  <!-- Affiliations (Borderless columns) -->
  <section class="py-24 border-b border-editorial bg-grain">
    <Container size="default">
      <SectionHeading
        eyebrow="Réseau"
        title="Nos affiliations"
        lead="L'église s'inscrit dans un réseau national officiel."
        class="mb-16"
      />

      <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
        {church.affiliations.map((a) => (
          <div class="flex flex-col justify-between border-t border-editorial pt-6">
            <div>
              <h3 class="font-display text-lg font-medium text-ink-900 dark:text-ink-50">
                {a.name}
              </h3>
              <p class="mt-2 text-xs text-ink-500 dark:text-ink-400">
                {a.fullName}
              </p>
            </div>
            <a
              href={a.url}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-6 inline-flex items-center gap-1 text-xs font-semibold uppercase tracking-wider text-terracotta-700 hover:underline dark:text-terracotta-300"
            >
              Visiter le site
              <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
            </a>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- CTA -->
  <section class="py-24 bg-grain">
    <Container size="narrow" class="text-center">
      <h2 class="font-display text-3xl font-light text-ink-900 dark:text-ink-50">
        Vous souhaitez en savoir plus ?
      </h2>
      <p class="mt-4 text-base text-ink-600 dark:text-ink-300 max-w-lg mx-auto">
        Venez nous rencontrer directement le dimanche matin ou écrivez-nous pour échanger en privé.
      </p>
      <div class="mt-10 flex justify-center gap-4">
        <Button href="/premiere-visite" variant="primary" size="lg">
          Préparer ma visite
        </Button>
        <Button href="/contact" variant="secondary" size="lg">
          Nous écrire
        </Button>
      </div>
    </Container>
  </section>
</PageLayout>
