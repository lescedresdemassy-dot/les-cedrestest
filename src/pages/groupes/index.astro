---
import PageLayout from '../../layouts/PageLayout.astro';
import Container from '../../components/Container.astro';
import { homeGroups } from '../../data/groups.ts';
import { church } from '../../data/church.ts';

const groupsByDay = {
  mercredi: homeGroups.filter((g) => g.day === 'mercredi'),
  jeudi: homeGroups.filter((g) => g.day === 'jeudi'),
  vendredi: homeGroups.filter((g) => g.day === 'vendredi'),
};
export const prerender = true;
---

<PageLayout
  title="Groupes de quartier — Trouvez un groupe près de chez vous"
  description="Rencontres de proximité en semaine pour prier et étudier la Bible ensemble, à Massy et dans les communes limitrophes."
  eyebrow="Groupes"
  pageTitle="Groupes de quartier"
  pageLead="En complément du culte dominical, nos groupes de quartier se réunissent en semaine dans des foyers pour prier, partager et approfondir la Bible ensemble."
>
  <!-- Leaflet CSS loaded in head -->
  <slot name="head">
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
      integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
      crossorigin=""
    />
  </slot>

  <!-- ============ INTERACTIVE MAP SECTION ============ -->
  <section class="py-12 bg-grain">
    <Container size="wide">
      <div
        id="groups-map"
        class="h-[55vh] min-h-[420px] w-full overflow-hidden rounded-none border border-editorial bg-sand-100 dark:bg-ink-900"
        aria-label="Carte interactive des groupes de quartier"
      >
        <noscript>
          <div class="flex h-full items-center justify-center p-8 text-center bg-white dark:bg-ink-900">
            <p class="max-w-md text-sm text-ink-600 dark:text-ink-400">
              La carte interactive nécessite l'activation de JavaScript. Vous pouvez toujours consulter la liste des groupes ci-dessous.
            </p>
          </div>
        </noscript>
      </div>
    </Container>
  </section>

  <!-- ============ GROUPS LIST & FILTER SECTION ============ -->
  <section class="py-16 bg-grain">
    <Container size="default">
      
      <!-- Typographic Filter Bar (No Rounded Pills) -->
      <div class="mb-12 flex flex-wrap items-center gap-6 border-b border-editorial pb-6">
        <span class="text-xs font-semibold uppercase tracking-[0.2em] text-ink-500 mr-2">Filtrer par jour&nbsp;:</span>
        
        <button
          type="button"
          data-filter-day=""
          class="filter-pill border-b-2 border-terracotta-600 pb-1 text-xs font-semibold uppercase tracking-wider text-terracotta-700 transition-all dark:text-terracotta-300"
        >
          Tous
        </button>
        <button
          type="button"
          data-filter-day="mercredi"
          class="filter-pill border-b-2 border-transparent pb-1 text-xs font-semibold uppercase tracking-wider text-ink-600 hover:text-terracotta-700 transition-all dark:text-ink-300"
        >
          Mercredi ({groupsByDay.mercredi.length})
        </button>
        <button
          type="button"
          data-filter-day="jeudi"
          class="filter-pill border-b-2 border-transparent pb-1 text-xs font-semibold uppercase tracking-wider text-ink-600 hover:text-terracotta-700 transition-all dark:text-ink-300"
        >
          Jeudi ({groupsByDay.jeudi.length})
        </button>
        <button
          type="button"
          data-filter-day="vendredi"
          class="filter-pill border-b-2 border-transparent pb-1 text-xs font-semibold uppercase tracking-wider text-ink-600 hover:text-terracotta-700 transition-all dark:text-ink-300"
        >
          Vendredi ({groupsByDay.vendredi.length})
        </button>
      </div>

      <!-- Groups Grid (Flat Typographic layout) -->
      <div class="grid grid-cols-1 gap-x-8 gap-y-16 sm:grid-cols-2 lg:grid-cols-3" data-groups-grid>
        {homeGroups.map((g) => (
          <article
            data-group-item
            data-group-day={g.day}
            data-group-id={g.id}
            class="group relative flex flex-col justify-between border-t border-editorial pt-6"
          >
            <div>
              <div class="flex items-center justify-between text-xs mb-4">
                <span class="font-semibold uppercase tracking-wider text-terracotta-700 dark:text-terracotta-300">
                  {g.day} · {g.time}
                </span>
                {g.accepting && (
                  <span class="inline-flex items-center gap-1.5 font-medium text-sage-700 dark:text-sage-400">
                    <span class="h-1.5 w-1.5 bg-sage-500 rounded-none animate-pulse-soft" />
                    Place disponible
                  </span>
                )}
              </div>

              <h3 class="font-display text-xl font-medium tracking-tight text-ink-900 dark:text-ink-50">
                {g.name}
              </h3>
              
              <p class="mt-1.5 text-xs text-ink-500 dark:text-ink-400 uppercase tracking-wider">
                Secteur&nbsp;: {g.area}
              </p>

              <p class="mt-4 text-sm leading-relaxed text-ink-600 dark:text-ink-400">
                {g.description}
              </p>
            </div>

            <div class="mt-8">
              <div class="border-t border-editorial-subtle py-3 text-xs text-ink-500 dark:text-ink-400">
                Coordonné par <span class="font-medium text-ink-800 dark:text-ink-200">{g.leaderName}</span>
              </div>
              <button
                type="button"
                class="inline-flex h-11 w-full items-center justify-center gap-2 rounded-none border border-ink-900 bg-transparent text-xs font-semibold uppercase tracking-[0.15em] text-ink-900 hover:bg-ink-900 hover:text-white dark:border-ink-100 dark:text-ink-100 dark:hover:bg-ink-100 dark:hover:text-ink-950 transition-all duration-200"
                data-group-join-button
                data-group-name={g.name}
                data-group-id={g.id}
              >
                Rejoindre ce groupe
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
              </button>
            </div>
          </article>
        ))}
      </div>

    </Container>
  </section>

  <!-- ============ JOIN MODAL (ACCESSIBLE REDESIGN) ============ -->
  <div
    id="join-modal"
    class="invisible fixed inset-0 z-50 opacity-0 transition-all duration-300"
    aria-hidden="true"
    role="dialog"
    aria-labelledby="join-modal-title"
    aria-modal="true"
  >
    <div class="absolute inset-0 bg-ink-950/60 backdrop-blur-xs" data-modal-backdrop></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
      <div class="relative max-h-[90vh] w-full max-w-lg overflow-y-auto rounded-none border border-editorial bg-white p-8 dark:bg-ink-900">
        
        <!-- Close Button -->
        <button
          type="button"
          class="absolute right-4 top-4 inline-flex h-10 w-10 items-center justify-center rounded-none text-ink-400 hover:bg-sand-100 hover:text-ink-900 dark:hover:bg-ink-800 dark:hover:text-ink-50 transition-colors"
          data-modal-close
          aria-label="Fermer la boîte de dialogue"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>

        <h2 id="join-modal-title" class="font-display text-2xl font-light tracking-tight text-ink-900 dark:text-ink-50">
          Demande de contact&nbsp;: <br/>
          <span data-modal-group-name class="text-terracotta-700 dark:text-terracotta-300"></span>
        </h2>
        <p class="mt-3 text-sm text-ink-600 dark:text-ink-400">
          Entrez vos coordonnées pour que l'animateur du groupe puisse vous recontacter.
        </p>

        <form id="join-form" class="mt-6 space-y-6">
          <input type="hidden" name="groupId" data-modal-group-id />
          <input type="hidden" name="csrfToken" data-csrf-token />
          <input type="text" name="website" class="honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />

          <div>
            <label for="join-name" class="block text-xs font-semibold uppercase tracking-wider text-ink-700 dark:text-ink-200">
              Votre nom complet *
            </label>
            <input
              type="text"
              id="join-name"
              name="name"
              required
              minlength="2"
              maxlength="100"
              class="input-editorial mt-1"
            />
          </div>

          <div>
            <label for="join-email" class="block text-xs font-semibold uppercase tracking-wider text-ink-700 dark:text-ink-200">
              Adresse email *
            </label>
            <input
              type="email"
              id="join-email"
              name="email"
              required
              maxlength="254"
              class="input-editorial mt-1"
            />
          </div>

          <div>
            <label for="join-phone" class="block text-xs font-semibold uppercase tracking-wider text-ink-700 dark:text-ink-200">
              Téléphone <span class="font-normal text-ink-500">(facultatif)</span>
            </label>
            <input
              type="tel"
              id="join-phone"
              name="phone"
              maxlength="20"
              class="input-editorial mt-1"
            />
          </div>

          <div>
            <label for="join-message" class="block text-xs font-semibold uppercase tracking-wider text-ink-700 dark:text-ink-200">
              Un mot pour présenter votre demande <span class="font-normal text-ink-500">(facultatif)</span>
            </label>
            <textarea
              id="join-message"
              name="message"
              rows="3"
              maxlength="500"
              class="input-editorial mt-1 resize-y"
            ></textarea>
          </div>

          <div class="flex gap-3 pt-2">
            <button
              type="submit"
              class="inline-flex h-12 w-full items-center justify-center gap-2 rounded-none bg-ink-900 text-xs font-semibold uppercase tracking-[0.15em] text-white hover:bg-terracotta-700 dark:bg-ink-100 dark:text-ink-950 dark:hover:bg-terracotta-400 transition-all duration-200"
            >
              Envoyer la demande d'inscription
            </button>
          </div>

          <p data-form-result class="hidden text-sm font-medium" role="status" aria-live="polite"></p>
        </form>
      </div>
    </div>
  </div>

  <!-- Leaflet map setup -->
  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin=""
    is:inline
  ></script>

  <script define:vars={{ groups: homeGroups, churchLat: church.address.coordinates.lat, churchLng: church.address.coordinates.lng, churchName: church.name }}>
    function setupMap() {
      if (typeof L === 'undefined') {
        setTimeout(setupMap, 100);
        return;
      }
      const mapEl = document.getElementById('groups-map');
      if (!mapEl || mapEl.dataset.initialized === 'true') return;
      mapEl.dataset.initialized = 'true';

      const map = L.map(mapEl, {
        center: [churchLat, churchLng],
        zoom: 12,
        scrollWheelZoom: false,
      });

      L.tileLayer(
        'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
        {
          attribution: '© OpenStreetMap',
          maxZoom: 18,
        }
      ).addTo(map);

      // Main church marker divIcon
      const churchIcon = L.divIcon({
        className: 'church-marker',
        html: '<div style="background:#c44d2a;color:white;width:30px;height:30px;display:flex;align-items:center;justify-content:center;border:2px solid white;font-size:14px;font-weight:bold;">✦</div>',
        iconSize: [30, 30],
        iconAnchor: [15, 15],
      });

      L.marker([churchLat, churchLng], { icon: churchIcon })
        .addTo(map)
        .bindPopup(`<strong>${churchName}</strong><br/>Bâtiment principal Les Cèdres`);

      // Add group markers
      const markers = {};
      groups.forEach((g) => {
        const groupIcon = L.divIcon({
          className: 'group-marker',
          html: `<div style="background:#476645;color:white;width:24px;height:24px;display:flex;align-items:center;justify-content:center;border:2px solid white;font-size:10px;font-weight:700;font-family:system-ui;">${g.day.charAt(0).toUpperCase()}</div>`,
          iconSize: [24, 24],
          iconAnchor: [12, 12],
        });
        const marker = L.marker([g.latitude, g.longitude], { icon: groupIcon })
          .addTo(map)
          .bindPopup(
            `<strong>${g.name}</strong><br/><span style="text-transform:capitalize">${g.day}</span> · ${g.time}<br/><span style="color:#666;font-size:11px">${g.area}</span>`
          );
        markers[g.id] = marker;
      });

      const allPoints = [
        [churchLat, churchLng],
        ...groups.map((g) => [g.latitude, g.longitude]),
      ];
      map.fitBounds(allPoints, { padding: [30, 30] });

      map.on('click', () => map.scrollWheelZoom.enable());
      map.on('mouseout', () => map.scrollWheelZoom.disable());

      document.querySelectorAll('[data-group-item]').forEach((card) => {
        card.addEventListener('mouseenter', () => {
          const id = card.dataset.groupId;
          if (id && markers[id]) markers[id].openPopup();
        });
      });
    }

    function setupFilters() {
      const pills = document.querySelectorAll('.filter-pill');
      const items = document.querySelectorAll('[data-group-item]');
      pills.forEach((pill) => {
        pill.addEventListener('click', () => {
          const day = pill.dataset.filterDay ?? '';
          
          pills.forEach((p) => {
            p.classList.remove('border-terracotta-600', 'text-terracotta-700', 'dark:text-terracotta-300');
            p.classList.add('border-transparent', 'text-ink-650', 'dark:text-ink-300');
          });
          
          pill.classList.add('border-terracotta-600', 'text-terracotta-700', 'dark:text-terracotta-300');
          pill.classList.remove('border-transparent', 'text-ink-650', 'dark:text-ink-300');
          
          items.forEach((item) => {
            const itemDay = item.dataset.groupDay;
            item.style.display = !day || itemDay === day ? '' : 'none';
          });
        });
      });
    }

    function setupModal() {
      const modal = document.getElementById('join-modal');
      const form = document.getElementById('join-form');
      const result = document.querySelector('[data-form-result]');
      if (!modal || !form) return;

      const open = (groupId, groupName) => {
        const nameEl = modal.querySelector('[data-modal-group-name]');
        const idEl = modal.querySelector('[data-modal-group-id]');
        if (nameEl) nameEl.textContent = groupName;
        if (idEl) idEl.value = groupId;
        modal.classList.remove('invisible', 'opacity-0');
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      };
      const close = () => {
        modal.classList.add('invisible', 'opacity-0');
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        if (result) {
          result.classList.add('hidden');
          result.textContent = '';
        }
      };

      document.querySelectorAll('[data-group-join-button]').forEach((btn) => {
        btn.addEventListener('click', () => {
          open(btn.dataset.groupId, btn.dataset.groupName);
        });
      });

      modal.querySelector('[data-modal-close]')?.addEventListener('click', close);
      modal.querySelector('[data-modal-backdrop]')?.addEventListener('click', close);
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !modal.classList.contains('invisible')) close();
      });

      // Fetch CSRF
      fetch('/api/csrf')
        .then((r) => r.json())
        .then((d) => {
          const tokenInput = modal.querySelector('[data-csrf-token]');
          if (tokenInput && d.token) tokenInput.value = d.token;
        })
        .catch(() => {});

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = Object.fromEntries(new FormData(form).entries());
        if (result) {
          result.className = 'text-xs font-semibold uppercase tracking-wider text-ink-500';
          result.classList.remove('hidden');
          result.textContent = 'Envoi de la demande...';
        }
        try {
          const res = await fetch('/api/group-join', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(formData),
          });
          const data = await res.json();
          if (result) {
            if (data.ok || data.success) {
              result.className = 'text-sm font-medium text-sage-700 dark:text-sage-400';
              result.textContent = '✓ Demande envoyée ! Nous vous contacterons rapidement.';
              form.reset();
              setTimeout(close, 2000);
            } else {
              result.className = 'text-sm font-medium text-terracotta-700 dark:text-terracotta-400';
              result.textContent = data.error || 'Une erreur s\'est produite. Réessayez.';
            }
          }
        } catch (err) {
          if (result) {
            result.className = 'text-sm font-medium text-terracotta-700 dark:text-terracotta-400';
            result.textContent = 'Erreur réseau. Vérifiez votre connexion.';
          }
        }
      });
    }

    function init() {
      setupMap();
      setupFilters();
      setupModal();
    }

    if (document.readyState !== 'loading') init();
    else document.addEventListener('DOMContentLoaded', init);
    document.addEventListener('astro:page-load', init);
  </script>
</PageLayout>
