---
import type { Sermon } from '../data/sermons';

interface Props {
  sermon: Sermon;
  featured?: boolean;
  class?: string;
}

const { sermon, featured = false, class: className = '' } = Astro.props;

// YouTube thumbnail (high quality)
const thumbnail = `https://i.ytimg.com/vi/${sermon.youtubeId}/maxresdefault.jpg`;
const thumbnailFallback = `https://i.ytimg.com/vi/${sermon.youtubeId}/hqdefault.jpg`;

const dateFr = new Date(sermon.date).toLocaleDateString('fr-FR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<article
  class:list={[
    'group relative flex flex-col transition-all duration-400',
    featured && 'lg:grid lg:grid-cols-12 lg:gap-12 lg:items-center',
    className,
  ]}
>
  <!-- Thumbnail Crop (Strictly sharp rectangular crop with fine border) -->
  <a
    href={`/sermons/${sermon.id}`}
    class:list={[
      'relative block overflow-hidden bg-sand-100 dark:bg-ink-850 rounded-none border border-editorial',
      featured ? 'lg:col-span-7 aspect-video' : 'aspect-video w-full',
    ]}
    aria-label={`Voir la prédication : ${sermon.title}`}
  >
    <img
      src={thumbnail}
      onerror={`this.onerror=null;this.src='${thumbnailFallback}';`}
      alt=""
      loading="lazy"
      decoding="async"
      width="640"
      height="360"
      class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-out-expo group-hover:scale-102"
    />

    <!-- Overlay & play indicator -->
    <div
      class="absolute inset-0 bg-ink-950/10 transition-opacity duration-300 group-hover:opacity-25"
      aria-hidden="true"
    ></div>

    <div class="absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-350 group-hover:opacity-100">
      <span class="flex h-12 w-12 items-center justify-center rounded-none bg-ink-900 text-white dark:bg-ink-50 dark:text-ink-950" aria-hidden="true">
        <svg class="ml-0.5 h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"></path></svg>
      </span>
    </div>

    {sermon.durationMinutes && (
      <span class="absolute bottom-3 right-3 rounded-none bg-ink-950/80 px-2 py-0.5 text-[10px] font-medium text-white tracking-wide">
        {sermon.durationMinutes} min
      </span>
    )}
  </a>

  <!-- Content Block -->
  <div class:list={[
    'flex flex-col pt-4',
    featured ? 'lg:col-span-5 lg:pt-0' : '',
  ]}>
    <div class="flex items-center gap-2 text-[10px] uppercase tracking-[0.15em] text-ink-500 dark:text-ink-400">
      <time datetime={sermon.date}>{dateFr}</time>
      {sermon.scripture && (
        <>
          <span>·</span>
          <span class="font-medium text-terracotta-700 dark:text-terracotta-300">{sermon.scripture}</span>
        </>
      )}
    </div>

    <h3 class:list={[
      'font-display font-medium tracking-tight text-ink-900 dark:text-ink-50 text-balance mt-3',
      featured ? 'text-2xl sm:text-3xl lg:text-4xl' : 'text-lg group-hover:text-terracotta-700 dark:group-hover:text-terracotta-300 transition-colors',
    ]}>
      <a href={`/sermons/${sermon.id}`}>
        {sermon.title}
      </a>
    </h3>

    <p class="mt-1 text-[10px] uppercase tracking-wider text-ink-400 dark:text-ink-500 font-medium">
      {sermon.speaker}
    </p>

    {featured && sermon.description && (
      <p class="mt-4 text-sm leading-relaxed text-ink-600 dark:text-ink-300">
        {sermon.description}
      </p>
    )}

    <div class="mt-4 pt-1">
      <span class="inline-flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wider text-terracotta-700 group-hover:text-terracotta-800 dark:text-terracotta-300 dark:group-hover:text-terracotta-200 transition-colors">
        Regarder
        <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </span>
    </div>
  </div>
</article>
