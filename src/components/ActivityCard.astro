---
import type { Activity } from '../data/activities';

interface Props {
  activity: Activity;
  class?: string;
}

const { activity, class: className = '' } = Astro.props;

// Map des icônes SVG (inline pour zéro requête)
const iconPaths: Record<string, string> = {
  sun: '<circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>',
  baby: '<path d="M9 12h.01"/><path d="M15 12h.01"/><path d="M10 16c.5.3 1.2.5 2 .5s1.5-.2 2-.5"/><path d="M19 6.3a9 9 0 0 1 1.8 3.9 2 2 0 0 1 0 3.6 9 9 0 0 1-17.6 0 2 2 0 0 1 0-3.6A9 9 0 0 1 12 3c2 0 3.5 1.1 3.5 2.5s-.9 2.5-2 2.5c-.8 0-1.5-.4-1.5-1"/>',
  children: '<circle cx="9" cy="12" r="3"/><circle cx="15" cy="12" r="3"/><path d="M9 17v2"/><path d="M15 17v2"/><path d="M5 17h14a2 2 0 0 1 2 2v0"/>',
  meal: '<path d="M3 11v3a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1v-3"/><path d="M12 19H4a1 1 0 0 1-1-1v-2a1 1 0 0 1 1-1h16a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1h-3.83"/><path d="M11 4v4"/><path d="M15 4v4"/><path d="M7 4v4"/><path d="M19 4v4"/>',
  youth: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  home: '<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>',
  seniors: '<circle cx="12" cy="6" r="3"/><path d="M12 9v3"/><path d="M9 14h6l-3 4z"/><path d="M9 18h6"/>',
  book: '<path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>',
};

const categoryColors: Record<Activity['category'], string> = {
  dimanche: 'bg-terracotta-100 text-terracotta-700 dark:bg-terracotta-950/40 dark:text-terracotta-300',
  semaine: 'bg-sage-100 text-sage-700 dark:bg-sage-950/40 dark:text-sage-300',
  jeunes: 'bg-sand-200 text-sand-800 dark:bg-sand-950/40 dark:text-sand-300',
  famille: 'bg-terracotta-100 text-terracotta-700 dark:bg-terracotta-950/40 dark:text-terracotta-300',
  biblique: 'bg-sage-100 text-sage-700 dark:bg-sage-950/40 dark:text-sage-300',
};

const categoryLabels: Record<Activity['category'], string> = {
  dimanche: 'Dimanche',
  semaine: 'En semaine',
  jeunes: 'Jeunes',
  famille: 'Famille',
  biblique: 'Étude biblique',
};
---

<article
  class:list={[
    'group relative flex flex-col rounded-3xl border border-sand-200 bg-white p-8 transition-all duration-500 ease-out-expo hover:-translate-y-1 hover:border-sand-300 hover:shadow-soft-lg dark:border-ink-800 dark:bg-ink-900 dark:hover:border-ink-700',
    activity.highlight && 'ring-1 ring-terracotta-200/60 dark:ring-terracotta-900/40',
    className,
  ]}
>
  <!-- Top : icon + category -->
  <div class="mb-6 flex items-start justify-between">
    <div
      class="flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-sand-100 to-sand-200 text-terracotta-700 dark:from-ink-800 dark:to-ink-900 dark:text-terracotta-300"
    >
      <svg
        width="26"
        height="26"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        set:html={iconPaths[activity.icon] ?? iconPaths.home}
      />
    </div>

    <span
      class:list={[
        'rounded-full px-3 py-1 text-xs font-medium',
        categoryColors[activity.category],
      ]}
    >
      {categoryLabels[activity.category]}
    </span>
  </div>

  <!-- Content -->
  <h3
    class="font-display text-xl font-medium tracking-tight text-ink-900 dark:text-ink-50"
  >
    {activity.title}
  </h3>

  <p class="mt-3 text-sm leading-relaxed text-ink-600 dark:text-ink-400">
    {activity.description}
  </p>

  <!-- Meta -->
  <div
    class="mt-6 space-y-2 border-t border-sand-200 pt-5 text-sm dark:border-ink-800"
  >
    <div class="flex items-start gap-2 text-ink-700 dark:text-ink-300">
      <svg
        class="mt-0.5 h-4 w-4 shrink-0 text-terracotta-600 dark:text-terracotta-400"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="10"></circle>
        <polyline points="12 6 12 12 16 14"></polyline>
      </svg>
      <span>{activity.schedule}</span>
    </div>

    {
      activity.location && (
        <div class="flex items-start gap-2 text-ink-700 dark:text-ink-300">
          <svg class="mt-0.5 h-4 w-4 shrink-0 text-terracotta-600 dark:text-terracotta-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 7-8 13-8 13s-8-6-8-13a8 8 0 0 1 16 0Z" /><circle cx="12" cy="10" r="3" /></svg>
          <span class="text-pretty">{activity.location}</span>
        </div>
      )
    }

    <div class="flex items-start gap-2 text-ink-700 dark:text-ink-300">
      <svg
        class="mt-0.5 h-4 w-4 shrink-0 text-terracotta-600 dark:text-terracotta-400"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
        <circle cx="9" cy="7" r="4"></circle>
        <path d="M22 21v-2a4 4 0 0 0-3-3.87"></path>
        <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
      </svg>
      <span class="text-pretty">{activity.audience}</span>
    </div>
  </div>
</article>
