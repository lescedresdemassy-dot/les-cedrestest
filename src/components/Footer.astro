---
import Logo from './Logo.astro';
import { church } from '../data/church.ts';

const year = new Date().getFullYear();

const links = {
  navigation: [
    { href: '/', label: 'Accueil' },
    { href: '/notre-adn', label: 'Notre ADN' },
    { href: '/activites', label: 'Activités' },
    { href: '/sermons', label: 'Prédications' },
    { href: '/groupes', label: 'Groupes' },
    { href: '/contact', label: 'Contact' },
  ],
  practical: [
    { href: '/mentions-legales', label: 'Mentions légales' },
    { href: '/confidentialite', label: 'Confidentialité' },
    { href: church.social.memberPortal, label: 'Espace membre', external: true },
  ],
  partners: church.affiliations,
};
---

<footer
  class="relative mt-32 overflow-hidden border-t border-sand-200 bg-gradient-to-b from-sand-50 to-sand-100 dark:border-ink-800 dark:from-ink-950 dark:to-ink-900"
  aria-labelledby="footer-heading"
>
  <h2 id="footer-heading" class="sr-only">Pied de page</h2>

  <!-- Decorative cedar silhouette -->
  <div
    class="pointer-events-none absolute -bottom-8 right-0 hidden opacity-[0.04] dark:opacity-[0.06] md:block"
    aria-hidden="true"
  >
    <svg width="500" height="500" viewBox="0 0 40 40" fill="currentColor">
      <path
        d="M20 4 L29 16 L26 16 L32 26 L25 26 L28 32 L12 32 L15 26 L8 26 L14 16 L11 16 Z"
        class="text-sage-700 dark:text-sage-300"
      />
    </svg>
  </div>

  <div class="container-prose relative">
    <!-- Main footer content -->
    <div class="grid grid-cols-1 gap-12 py-16 md:grid-cols-2 lg:grid-cols-4 lg:py-20">
      <!-- Brand column -->
      <div class="lg:col-span-1">
        <Logo />
        <p
          class="mt-6 max-w-xs text-sm leading-relaxed text-ink-600 dark:text-ink-400"
        >
          {church.baseline}
        </p>
        <div class="mt-6 flex items-center gap-3">
          <a
            href={church.social.youtube.channel}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-ink-900/10 text-ink-700 transition-colors hover:border-terracotta-600 hover:bg-terracotta-50 hover:text-terracotta-700 dark:border-ink-50/10 dark:text-ink-300 dark:hover:bg-terracotta-950/40"
            aria-label="Chaîne YouTube de l'EEB Massy"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z" />
            </svg>
          </a>
          <a
            href={church.social.memberPortal}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex h-10 items-center gap-2 rounded-full border border-ink-900/10 px-4 text-xs font-medium text-ink-700 transition-colors hover:border-terracotta-600 hover:bg-terracotta-50 hover:text-terracotta-700 dark:border-ink-50/10 dark:text-ink-300 dark:hover:bg-terracotta-950/40"
          >
            Espace membre
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M7 7h10v10" />
              <path d="M7 17 17 7" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Practical info -->
      <div>
        <h3 class="font-display text-base font-medium text-ink-900 dark:text-ink-50">
          Nous rendre visite
        </h3>
        <address class="mt-5 space-y-3 text-sm not-italic text-ink-600 dark:text-ink-400">
          <div class="flex items-start gap-3">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-terracotta-600 dark:text-terracotta-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 7-8 13-8 13s-8-6-8-13a8 8 0 0 1 16 0Z" /><circle cx="12" cy="10" r="3" /></svg>
            <span>
              {church.address.street}<br />
              {church.address.postalCode} {church.address.city}
            </span>
          </div>
          <div class="flex items-start gap-3">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-terracotta-600 dark:text-terracotta-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" /></svg>
            <a href={`tel:${church.contact.phoneE164}`} class="hover:text-terracotta-700 dark:hover:text-terracotta-300">
              {church.contact.phone}
            </a>
          </div>
          <div class="flex items-start gap-3">
            <svg class="mt-0.5 h-4 w-4 shrink-0 text-terracotta-600 dark:text-terracotta-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="18" x="3" y="4" rx="2" ry="2" /><line x1="16" x2="16" y1="2" y2="6" /><line x1="8" x2="8" y1="2" y2="6" /><line x1="3" x2="21" y1="10" y2="10" /></svg>
            <span>
              Culte dimanche · {church.services.sunday.time}
            </span>
          </div>
        </address>
        <a
          href={church.address.googleMapsDirections}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-terracotta-700 transition-colors hover:text-terracotta-800 dark:text-terracotta-300 dark:hover:text-terracotta-200"
        >
          Voir l'itinéraire
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14" /><path d="m12 5 7 7-7 7" /></svg>
        </a>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="font-display text-base font-medium text-ink-900 dark:text-ink-50">
          Naviguer
        </h3>
        <ul class="mt-5 space-y-3 text-sm">
          {
            links.navigation.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-ink-600 transition-colors hover:text-terracotta-700 dark:text-ink-400 dark:hover:text-terracotta-300"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Affiliations -->
      <div>
        <h3 class="font-display text-base font-medium text-ink-900 dark:text-ink-50">
          Affiliations
        </h3>
        <ul class="mt-5 space-y-3 text-sm">
          {
            links.partners.map((link) => (
              <li>
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1 text-ink-600 transition-colors hover:text-terracotta-700 dark:text-ink-400 dark:hover:text-terracotta-300"
                  title={link.fullName}
                >
                  {link.name}
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path d="M7 7h10v10" />
                    <path d="M7 17 17 7" />
                  </svg>
                </a>
              </li>
            ))
          }
        </ul>

        <h3 class="mt-8 font-display text-base font-medium text-ink-900 dark:text-ink-50">
          Légal
        </h3>
        <ul class="mt-5 space-y-3 text-sm">
          {
            links.practical.slice(0, 2).map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-ink-600 transition-colors hover:text-terracotta-700 dark:text-ink-400 dark:hover:text-terracotta-300"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div
      class="flex flex-col items-start gap-4 border-t border-sand-200 py-8 text-xs text-ink-500 dark:border-ink-800 dark:text-ink-400 md:flex-row md:items-center md:justify-between"
    >
      <p>
        © {year} {church.name}. Tous droits réservés.
      </p>
      <p class="text-ink-400 dark:text-ink-500">
        Bâti avec soin pour notre communauté. ✦
      </p>
    </div>
  </div>
</footer>
