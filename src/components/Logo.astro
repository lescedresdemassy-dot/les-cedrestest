---
/**
 * Logo EEB Massy — Logo original du site.
 */
interface Props {
  class?: string;
  variant?: 'full' | 'icon';
  href?: string;
}

const { class: className = '', href = '/' } = Astro.props;
---

<a
  href={href}
  class={`inline-flex items-center ${className}`}
  aria-label="Église Évangélique Baptiste de Massy — Accueil"
>
  <img
    src="/logo-original.jpg"
    alt="Église Évangélique Baptiste de Massy"
    class="h-10 w-auto object-contain mix-blend-multiply dark:mix-blend-screen dark:invert"
    width="128"
    height="40"
    loading="eager"
  />
</a>

