---
import Logo from './Logo.astro';
import DarkModeToggle from './DarkModeToggle.astro';

const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/premiere-visite', label: 'Première visite' },
  { href: '/notre-adn', label: 'Notre ADN' },
  { href: '/activites', label: 'Activités' },
  { href: '/sermons', label: 'Prédications' },
  { href: '/groupes', label: 'Groupes' },
];

const currentPath = Astro.url.pathname;
function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-50 border-b border-ink-900/5 bg-sand-50/70 backdrop-blur-xl transition-all duration-400 ease-out-expo dark:border-ink-50/5 dark:bg-ink-950/70"
  data-scrolled="false"
>
  <!-- Skip link accessibility -->
  <a href="#main-content" class="skip-link">Aller au contenu principal</a>

  <div
    class="mx-auto flex h-20 max-w-7xl items-center justify-between px-4 transition-all duration-400 sm:px-6 lg:px-8"
    id="header-inner"
  >
    <Logo />

    <!-- Desktop nav -->
    <nav class="hidden lg:flex" aria-label="Navigation principale">
      <ul class="flex items-center gap-8">
        {
          navLinks.map((link, index) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'relative inline-flex items-center font-sans text-[11px] uppercase tracking-[0.2em] font-medium transition-colors duration-200 py-1.5',
                  isActive(link.href)
                    ? 'text-terracotta-700 dark:text-terracotta-300'
                    : 'text-ink-700 hover:text-ink-900 dark:text-ink-300 dark:hover:text-ink-100',
                ]}
                aria-current={isActive(link.href) ? 'page' : undefined}
              >
                {isActive(link.href) ? (
                  <span class="mr-1 text-[9px] font-light text-terracotta-500/70">
                    [{String(index + 1).padStart(2, '0')}]
                  </span>
                ) : null}
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Right cluster -->
    <div class="flex items-center gap-6">
      <DarkModeToggle />
      
      <a 
        href="/contact" 
        class:list={[
          'hidden sm:inline-block font-sans text-[11px] uppercase tracking-[0.2em] font-semibold border-b pb-0.5 transition-colors',
          isActive('/contact')
            ? 'text-terracotta-700 border-terracotta-700/40 dark:text-terracotta-300 dark:border-terracotta-300/40'
            : 'text-ink-900 border-ink-900/20 hover:text-terracotta-700 hover:border-terracotta-700/40 dark:text-ink-50 dark:border-ink-50/20 dark:hover:text-terracotta-300 dark:hover:border-terracotta-300/40'
        ]}
      >
        Nous contacter &rarr;
      </a>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-button"
        type="button"
        class="inline-flex h-9 items-center justify-center font-sans text-[11px] uppercase tracking-[0.2em] font-semibold text-ink-900 dark:text-ink-50 lg:hidden"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        [ Menu ]
      </button>
    </div>
  </div>

  <!-- Mobile menu — full screen typographic directory overlay -->
  <div
    id="mobile-menu"
    class="invisible fixed inset-0 z-50 opacity-0 transition-all duration-400 ease-out-expo lg:hidden"
    aria-hidden="true"
  >
    <div
      id="mobile-menu-backdrop"
      class="absolute inset-0 bg-sand-50 transition-opacity duration-300 dark:bg-ink-950"
    >
    </div>

    <div class="relative flex h-full flex-col px-6 py-6 sm:px-8">
      <div class="flex items-center justify-between">
        <Logo />
        <button
          id="mobile-menu-close"
          type="button"
          class="inline-flex h-9 items-center justify-center font-sans text-[11px] uppercase tracking-[0.2em] font-semibold text-ink-900 dark:text-ink-50"
          aria-label="Fermer le menu"
        >
          [ Fermer ]
        </button>
      </div>

      <nav class="flex flex-1 flex-col justify-center py-12" aria-label="Navigation mobile">
        <ul class="divide-y divide-ink-900/10 dark:divide-ink-50/10 border-y border-ink-900/10 dark:border-ink-50/10">
          {
            navLinks.map((link, index) => (
              <li>
                <a
                  href={link.href}
                  class="flex items-center justify-between py-5 sm:py-6 group"
                  aria-current={isActive(link.href) ? 'page' : undefined}
                >
                  <div class="flex items-baseline gap-4">
                    <span class="font-sans text-[10px] tracking-wider text-ink-400 dark:text-ink-600">
                      {String(index + 1).padStart(2, '0')}
                    </span>
                    <span class:list={[
                      'font-display text-2xl sm:text-3xl font-medium tracking-tight transition-colors',
                      isActive(link.href)
                        ? 'text-terracotta-700 dark:text-terracotta-300'
                        : 'text-ink-900 group-hover:text-terracotta-700 dark:text-ink-100 dark:group-hover:text-terracotta-300'
                    ]}>
                      {link.label}
                    </span>
                  </div>
                  <span class="text-lg opacity-0 group-hover:opacity-100 transition-opacity text-terracotta-700 dark:text-terracotta-300">
                    &rarr;
                  </span>
                </a>
              </li>
            ))
          }
          <li>
            <a
              href="/contact"
              class="flex items-center justify-between py-5 sm:py-6 group"
            >
              <div class="flex items-baseline gap-4">
                <span class="font-sans text-[10px] tracking-wider text-ink-400 dark:text-ink-600">
                  {String(navLinks.length + 1).padStart(2, '0')}
                </span>
                <span class:list={[
                  'font-display text-2xl sm:text-3xl font-medium tracking-tight transition-colors',
                  isActive('/contact')
                    ? 'text-terracotta-700 dark:text-terracotta-300'
                    : 'text-ink-900 group-hover:text-terracotta-700 dark:text-ink-100 dark:group-hover:text-terracotta-300'
                ]}>
                  Nous contacter
                </span>
              </div>
              <span class="text-lg opacity-0 group-hover:opacity-100 transition-opacity text-terracotta-700 dark:text-terracotta-300">
                &rarr;
              </span>
            </a>
          </li>
        </ul>
      </nav>
    </div>
  </div>
</header>

<style>
  #site-header[data-scrolled='true'] {
    @apply bg-sand-50/90 dark:bg-ink-950/90 shadow-sm;
  }
  
  #site-header[data-scrolled='true'] #header-inner {
    @apply h-16;
  }

  #mobile-menu.is-open {
    @apply visible opacity-100;
  }
</style>

<script>
  function setupHeader() {
    const header = document.getElementById('site-header');
    if (!header) return;

    // Scroll effect
    const onScroll = () => {
      const scrolled = window.scrollY > 12;
      header.dataset.scrolled = scrolled ? 'true' : 'false';
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    // Mobile menu
    const menu = document.getElementById('mobile-menu');
    const openBtn = document.getElementById('mobile-menu-button');
    const closeBtn = document.getElementById('mobile-menu-close');
    const backdrop = document.getElementById('mobile-menu-backdrop');

    if (!menu || !openBtn || !closeBtn || !backdrop) return;

    const open = () => {
      menu.classList.add('is-open');
      menu.setAttribute('aria-hidden', 'false');
      openBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      menu.classList.remove('is-open');
      menu.setAttribute('aria-hidden', 'true');
      openBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    };

    openBtn.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    backdrop.addEventListener('click', close);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.classList.contains('is-open')) close();
    });

    // Close on link click
    menu.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => setTimeout(close, 100))
    );
  }

  if (document.readyState !== 'loading') setupHeader();
  else document.addEventListener('DOMContentLoaded', setupHeader);
</script>

