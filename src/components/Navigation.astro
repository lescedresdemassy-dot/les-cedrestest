---
import Logo from './Logo.astro';
import DarkModeToggle from './DarkModeToggle.astro';
import Button from './Button.astro';

const navLinks = [
  { href: '/', label: 'Accueil' },
  { href: '/notre-adn', label: 'Notre ADN' },
  { href: '/activites', label: 'Activités' },
  { href: '/sermons', label: 'Prédications' },
  { href: '/groupes', label: 'Groupes' },
];

const currentPath = Astro.url.pathname;
function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-40 transition-all duration-400 ease-out-expo"
  data-scrolled="false"
>
  <!-- Skip link accessibility -->
  <a href="#main-content" class="skip-link">Aller au contenu principal</a>

  <div
    class="mx-auto flex h-16 max-w-7xl items-center justify-between px-4 transition-all duration-400 sm:px-6 lg:px-8"
  >
    <Logo />

    <!-- Desktop nav -->
    <nav class="hidden lg:flex" aria-label="Navigation principale">
      <ul
        class="flex items-center gap-1 rounded-full border border-ink-900/8 bg-white/60 px-2 py-1.5 backdrop-blur-xl backdrop-saturate-150 dark:border-ink-50/8 dark:bg-ink-900/60"
      >
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={[
                  'relative inline-flex h-9 items-center rounded-full px-4 text-sm font-medium transition-colors duration-200',
                  isActive(link.href)
                    ? 'text-terracotta-700 dark:text-terracotta-300'
                    : 'text-ink-700 hover:text-ink-900 dark:text-ink-300 dark:hover:text-ink-100',
                ]}
                aria-current={isActive(link.href) ? 'page' : undefined}
              >
                {isActive(link.href) && (
                  <span
                    class="absolute inset-0 -z-10 rounded-full bg-terracotta-100/70 dark:bg-terracotta-950/40"
                    aria-hidden="true"
                  />
                )}
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Right cluster -->
    <div class="flex items-center gap-2">
      <DarkModeToggle />
      <div class="hidden sm:block">
        <Button href="/contact" variant="primary" size="sm" icon="arrow">
          Nous contacter
        </Button>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-button"
        type="button"
        class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-ink-900/10 bg-white/60 text-ink-800 backdrop-blur transition-colors hover:bg-white dark:border-ink-50/10 dark:bg-ink-900/60 dark:text-ink-100 dark:hover:bg-ink-900 lg:hidden"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg
          class="h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="4" x2="20" y1="6" y2="6"></line>
          <line x1="4" x2="20" y1="12" y2="12"></line>
          <line x1="4" x2="20" y1="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu — overlay full screen -->
  <div
    id="mobile-menu"
    class="invisible fixed inset-0 z-50 opacity-0 transition-all duration-300 lg:hidden"
    aria-hidden="true"
  >
    <div
      id="mobile-menu-backdrop"
      class="absolute inset-0 bg-ink-950/40 backdrop-blur-sm"
    >
    </div>

    <div
      class="absolute right-0 top-0 flex h-full w-full max-w-sm flex-col bg-sand-50 shadow-soft-xl dark:bg-ink-950"
    >
      <div class="flex items-center justify-between px-6 py-5">
        <Logo />
        <button
          id="mobile-menu-close"
          type="button"
          class="inline-flex h-10 w-10 items-center justify-center rounded-full text-ink-700 transition-colors hover:bg-sand-100 dark:text-ink-300 dark:hover:bg-ink-900"
          aria-label="Fermer le menu"
        >
          <svg
            class="h-5 w-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M18 6 6 18"></path>
            <path d="m6 6 12 12"></path>
          </svg>
        </button>
      </div>

      <nav class="flex-1 overflow-y-auto px-6 py-4" aria-label="Navigation mobile">
        <ul class="space-y-1">
          {
            navLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  class:list={[
                    'block rounded-2xl px-4 py-4 text-lg font-medium transition-colors',
                    isActive(link.href)
                      ? 'bg-terracotta-100 text-terracotta-800 dark:bg-terracotta-950/40 dark:text-terracotta-200'
                      : 'text-ink-800 hover:bg-sand-100 dark:text-ink-100 dark:hover:bg-ink-900',
                  ]}
                  aria-current={isActive(link.href) ? 'page' : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>

        <div class="mt-8 border-t border-sand-200 pt-6 dark:border-ink-800">
          <Button href="/contact" variant="primary" size="lg" icon="arrow" fullWidth>
            Nous contacter
          </Button>
        </div>
      </nav>
    </div>
  </div>
</header>

<style>
  #site-header[data-scrolled='true'] > div {
    @apply border-b border-sand-200/60 bg-sand-50/80 backdrop-blur-xl backdrop-saturate-150 dark:border-ink-800/60 dark:bg-ink-950/80;
  }

  #mobile-menu.is-open {
    @apply visible opacity-100;
  }

  #mobile-menu.is-open #mobile-menu-backdrop {
    @apply opacity-100;
  }
</style>

<script>
  function setupHeader() {
    const header = document.getElementById('site-header');
    if (!header) return;

    // Scroll effect
    const onScroll = () => {
      const scrolled = window.scrollY > 8;
      header.dataset.scrolled = scrolled ? 'true' : 'false';
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });

    // Mobile menu
    const menu = document.getElementById('mobile-menu');
    const openBtn = document.getElementById('mobile-menu-button');
    const closeBtn = document.getElementById('mobile-menu-close');
    const backdrop = document.getElementById('mobile-menu-backdrop');

    if (!menu || !openBtn || !closeBtn || !backdrop) return;

    const open = () => {
      menu.classList.add('is-open');
      menu.setAttribute('aria-hidden', 'false');
      openBtn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      menu.classList.remove('is-open');
      menu.setAttribute('aria-hidden', 'true');
      openBtn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    };

    openBtn.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    backdrop.addEventListener('click', close);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.classList.contains('is-open')) close();
    });

    // Close on link click
    menu.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => setTimeout(close, 100))
    );
  }

  if (document.readyState !== 'loading') setupHeader();
  else document.addEventListener('DOMContentLoaded', setupHeader);
</script>
